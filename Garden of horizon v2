-- AUTO BUY LOOP
-- Remote: PurchaseShopItem:InvokeServer("SeedShop", seedName)
-- Confirmed return signatures from SeedShopController (v_u_47):
--   pcall returns: ok=true,  v43=table,  v44=nil    → success
--   pcall returns: ok=true,  v43=false,  v44=reason → failure
--   pcall returns: ok=false, v43=errMsg             → network error
-- ══════════════════════════════════════════
task.spawn(function()
	while true do
		if autoBuyEnabled and selectedBuySeed and Remote then
			-- Skip invoke entirely if we already know this seed is out of stock
			-- (cache is cleared automatically on the SeedShop restock signal)
			local cachedStock = SeedStockData[selectedBuySeed]
			if cachedStock ~= nil and cachedStock <= 0 then
				if buyFailCount == 0 then
					showNotification("⚠ OUT OF STOCK: " .. selectedBuySeed .. " — waiting for restock", Color3.fromRGB(255, 80, 80), 5)
				end
				buyFailCount = buyFailCount + 1
				task.wait(BUY_DELAY)
				continue
			end

			-- Capture all 3 pcall returns: (ok, result, failReason)
			-- On success: ok=true, result=table, failReason=nil
			-- On failure: ok=true, result=false, failReason="Not enough shillings" etc.
			local ok, result, failReason = pcall(function()
				return Remote:InvokeServer("SeedShop", selectedBuySeed)
			end)

			local status, detail = parseBuyResult(ok, result, failReason)

			if status == "success" then
				-- Server returned updated stock table — apply it to cache
				parseStockTable(detail, SeedStockData)
				buyFailCount = 0

			elseif status == "out_of_stock" then
				-- Cache 0 so we stop invoking until the SeedShop restock signal fires
				SeedStockData[selectedBuySeed] = 0
				showNotification("⚠ OUT OF STOCK: " .. selectedBuySeed .. " — waiting for restock", Color3.fromRGB(255, 80, 80), 5)
				buyFailCount = 0
				-- Back off for a full cycle rather than spamming retries
				task.wait(10)

			elseif status == "no_money" then
				buyFailCount = buyFailCount + 1
				if buyFailCount >= 3 then
					showNotification("💸 NOT ENOUGH SHILLINGS to buy " .. selectedBuySeed, Color3.fromRGB(255, 180, 50), 5)
					buyFailCount = 0
				end

			elseif status == "full" then
				buyFailCount = buyFailCount + 1
				if buyFailCount >= 3 then
					showNotification("📦 INVENTORY FULL! Can't buy more " .. selectedBuySeed, Color3.fromRGB(255, 150, 50), 5)
					buyFailCount = 0
				end

			elseif status == "error" then
				-- pcall itself failed — likely network hiccup, back off
				buyFailCount = buyFailCount + 1
				if buyFailCount >= 5 then
					showNotification("❌ Remote error — check connection", Color3.fromRGB(255, 80, 80), 4)
					buyFailCount = 0
				end
				task.wait(1)

			else
				-- Unknown server rejection — print the raw reason for debugging
				buyFailCount = buyFailCount + 1
				if buyFailCount >= 3 then
					showNotification("❌ Buy rejected: " .. tostring(detail or "unknown reason"), Color3.fromRGB(255, 80, 80), 4)
					print("[FarmHub] Unhandled buy failure reason:", detail)
					buyFailCount = 0
				end
			end
		end
		task.wait(BUY_DELAY)
	end
end)

