			if savedCFrame then
				task.wait(0.3)
				local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
				if r then r.CFrame = savedCFrame end
			end

			task.wait(1.5) bb.Text="Buy" bb.Active=true
			TweenService:Create(bb,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(60,140,220)}):Play()
			GearStatusLabel.Text="Ready to purchase" GearStatusLabel.TextColor3=Color3.fromRGB(100,100,100)
			TweenService:Create(GearStatusDot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(100,100,100)}):Play()
		end)
	end

	-- Live stock label updater for gear items
	task.spawn(function()
		while ScreenGui and ScreenGui.Parent do
			for name, lbl in pairs(gearStockLabels) do
				local s = GearStockData[name]
