task.spawn(function()
	while true do
		if autoHarvestEnabled then
			local ch = player.Character
			local root = ch and ch:FindFirstChild("HumanoidRootPart")
			if root then
				makeAllPromptsInstant()
				task.wait(0.1)
				local plants = getAllHarvestablePlants()
				if #plants == 0 then
					task.wait(1)
				else
					for _, data in pairs(plants) do
						if not autoHarvestEnabled then break end
						if data.Part and data.Part.Parent and data.Prompt and data.Prompt.Parent then
							-- Re-enable prompt just before firing
							pcall(function()
								data.Prompt.HoldDuration = 0
								data.Prompt.MaxActivationDistance = 100
								data.Prompt.RequiresLineOfSight = false
								data.Prompt.Enabled = true
							end)

							-- PlatformStand-based teleport (zero glitch on mobile)
							safeTeleportForHarvest(root, data.Part.Position)

							-- On mobile give one extra frame for PlatformStand restore
							-- to propagate before firing the prompt
							task.wait(isMobile and 0.08 or 0.05)

							-- Fire the prompt
							firePrompt(data.Prompt)
							harvestCount = harvestCount + 1

							task.wait(HARVEST_DELAY)
						end
					end
				end
			end
		end
		task.wait(0.3)
	end
end)

