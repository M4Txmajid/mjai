	TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, isMobile and 42 or 48)}):Play()

	task.spawn(function()
		task.wait(duration)
		TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = UDim2.new(1, 0, 0, 0)}):Play()
		TweenService:Create(nst, TweenInfo.new(0.3), {Transparency = 1}):Play()
		task.wait(0.35)
		notif:Destroy()
	end)
end

