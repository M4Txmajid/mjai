			elseif status == "full" then
				bb.Text="Full!" TweenService:Create(bb,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(255,150,50)}):Play()
				GearStatusLabel.Text="📦 Inventory full!" GearStatusLabel.TextColor3=Color3.fromRGB(255,150,50)
