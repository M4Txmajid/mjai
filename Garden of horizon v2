-- REAL STOCK TRACKING
-- Stock data mirrors what the server sends back:
-- { Items = { ["Watering Can"] = { Amount = 5 }, ... } }
-- ══════════════════════════════════════════
local GearStockData = {}   -- [itemName] = amount (number), 0 = out of stock, nil = unknown
local SeedStockData = {}   -- [seedName] = amount (number), 0 = out of stock, nil = unknown

-- Parse the stock table returned by GetShopData or PurchaseShopItem success
local function parseStockTable(data, target)
	if type(data) ~= "table" then return end
	-- Server returns { Items = { [Name] = { Amount = N } } }
	local items = data.Items or data
	for name, info in pairs(items) do
		if type(info) == "table" and info.Amount ~= nil then
			target[name] = info.Amount
		elseif type(info) == "number" then
			target[name] = info
		end
	end
end

-- Fetch live stock from server for either "GearShop" or "SeedShop"
local function fetchShopStock(shopType)
	if not GetShopDataRemote then return end
	local ok, data = pcall(function()
		return GetShopDataRemote:InvokeServer(shopType)
	end)
	if ok and type(data) == "table" then
		if shopType == "GearShop" then
			parseStockTable(data, GearStockData)
		else
			parseStockTable(data, SeedStockData)
		end
	end
end

-- ══════════════════════════════════════════
-- BUY RESULT PARSER
-- Confirmed from both SeedShopController and GearShopController decompiles:
--
--   pcall(remote:InvokeServer(...)) returns:
--     ok=true,  result=table            → SUCCESS, result is updated stock table
--     ok=true,  result=false, v3=reason → FAIL, reason is exact server string
--     ok=false, result=errMsg           → pcall itself errored (network etc)
--
--   Exact server failure strings observed:
--     "Not enough shillings"   → no_money
--     "Out of stock" / NoStock UI visible check → out_of_stock
--     "Inventory full" (assumed) → full
-- ══════════════════════════════════════════
local function parseBuyResult(ok, result, reason)
	if not ok then
		-- pcall itself failed — result contains the error message
		return "error", tostring(result)
	end
	if type(result) == "table" then
		-- SUCCESS: server returned updated stock table
		return "success", result
	end
	-- FAIL: result == false or nil, reason is the 3rd pcall return value (v3/v44 in decompile)
	local r = tostring(reason or ""):lower()
	-- Exact match first (from decompile: v44 == "Not enough shillings")
	if reason == "Not enough shillings" or r:find("shilling") or r:find("not enough") or r:find("afford") then
		return "no_money", reason
	elseif r:find("out of stock") or r:find("sold out") or r:find("no stock") or r:find("stock") then
		return "out_of_stock", reason
	elseif r:find("full") or r:find("inventory") or r:find("space") then
		return "full", reason
	elseif reason ~= nil then
		return "failed", reason
	end
	return "unknown", reason
end

