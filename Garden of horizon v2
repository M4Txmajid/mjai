	ncr.Parent = notif

	local nst = Instance.new("UIStroke")
	nst.Color = color or Color3.fromRGB(200, 80, 80)
	nst.Thickness = 1
	nst.Parent = notif

	local colorBar = Instance.new("Frame")
	colorBar.Size = UDim2.new(0, 4, 1, -8)
	colorBar.Position = UDim2.new(0, 6, 0, 4)
	colorBar.BackgroundColor3 = color or Color3.fromRGB(200, 80, 80)
	colorBar.BorderSizePixel = 0
	colorBar.Parent = notif
	local cbcr = Instance.new("UICorner")
	cbcr.CornerRadius = UDim.new(0, 2)
	cbcr.Parent = colorBar

	local nl = Instance.new("TextLabel")
	nl.Size = UDim2.new(1, -25, 1, -8)
	nl.Position = UDim2.new(0, 18, 0, 4)
	nl.BackgroundTransparency = 1
	nl.Text = text
	nl.TextColor3 = Color3.fromRGB(255, 255, 255)
	nl.Font = Enum.Font.GothamBold
	nl.TextSize = isMobile and 11 or 13
	nl.TextXAlignment = Enum.TextXAlignment.Left
