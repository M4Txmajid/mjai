-- ══════════════════════════════════════════
-- AUTO HARVEST LOOP — mobile-safe v2
-- Root cause of joystick/jump glitch on mobile:
--   Setting root.CFrame directly while physics is running forces the engine
--   into a brief undefined fall state. On mobile this:
--     - Hides the jump button (engine thinks character is airborne/falling)
--     - Freezes the joystick (MoveDirection stays non-zero from last input)
--
-- Fix strategy:
--   1. PlatformStand = true  → suspends Humanoid physics entirely, no fall state
--   2. Anchor root briefly   → prevents physics engine from fighting the teleport
--   3. Set CFrame            → now purely a position change, no physics reaction
--   4. Unanchor              → physics resumes from the new position cleanly
--   5. PlatformStand = false → restores full control; joystick and jump reappear
--      instantly because the Humanoid never entered a fall/jump state
-- ══════════════════════════════════════════
local function safeTeleportForHarvest(root, targetPos)
	local humanoid = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
	if not humanoid then
		-- Fallback if humanoid not found — plain teleport
		root.CFrame = CFrame.new(targetPos.X, targetPos.Y + 2.5, targetPos.Z)
		return
	end

	if isMobile then
		-- Step 1: suspend humanoid physics so the engine doesn't react to the move
		humanoid.PlatformStand = true
		-- Step 2: anchor root so physics can't generate a fall/velocity
		root.Anchored = true
		-- Step 3: teleport — safe now, no physics reaction possible
		root.CFrame = CFrame.new(targetPos.X, targetPos.Y + 2.5, targetPos.Z)
		-- Step 4: unanchor before restoring control so character lands naturally
		root.Anchored = false
		-- Step 5: restore humanoid — joystick and jump button come back immediately
		--   because Humanoid was never in a jump/fall state during the move
		humanoid.PlatformStand = false
		-- Clear any stale jump flag
		humanoid.Jump = false
	else
		-- PC: plain teleport is fine, no joystick to glitch
