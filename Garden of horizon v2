				local pb=selectedPlantSeedBtn:FindFirstChild("SelectBar") if pb then TweenService:Create(pb,TweenInfo.new(0.15),{Size=UDim2.new(0,4,0,0)}):Play() end
				local pl=selectedPlantSeedBtn:FindFirstChildOfClass("TextLabel") if pl then TweenService:Create(pl,TweenInfo.new(0.2),{TextColor3=Color3.fromRGB(170,170,170)}):Play() end
				local ps=selectedPlantSeedBtn:FindFirstChildOfClass("UIStroke") if ps then TweenService:Create(ps,TweenInfo.new(0.2),{Color=Color3.fromRGB(45,45,45)}):Play() end
			end
			selectedPlantSeedBtn=sb selectedPlantSeed=seedName equipSeed(seedName)
			TweenService:Create(sb,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(35,45,35)}):Play()
			TweenService:Create(bar,TweenInfo.new(0.2),{Size=UDim2.new(0,4,0,28)}):Play()
			TweenService:Create(lb,TweenInfo.new(0.2),{TextColor3=Color3.fromRGB(255,255,255)}):Play()
			TweenService:Create(st,TweenInfo.new(0.2),{Color=Color3.fromRGB(80,200,80)}):Play()
			PlantToggleDesc.Text="Selected: "..seedName PlantToggleDesc.TextColor3=Color3.fromRGB(80,200,80)
			if autoPlantEnabled then PlantStatusLabel.Text="Planting - "..seedName..(currentPlot and (" @ "..currentPlot) or "") end
		end)
		return sb
	end

	local function refreshPlantSeeds(silent)
		if autoPlantEnabled then return end
		local prev=selectedPlantSeed
		for _,ch in pairs(PlantSeedGrid:GetChildren()) do if ch:IsA("TextButton") then ch:Destroy() end end
		selectedPlantSeedBtn=nil
		local seeds=getAllSeeds()
		if #seeds==0 then NoSeedsLabel.Visible=true
			if not silent then selectedPlantSeed=nil PlantToggleDesc.Text="Select a seed from backpack" PlantToggleDesc.TextColor3=Color3.fromRGB(100,100,100) end
		else
			NoSeedsLabel.Visible=false
			for i,sn in ipairs(seeds) do
				local btn=createPlantSeedButton(sn,i)
				if sn==prev then selectedPlantSeedBtn=btn selectedPlantSeed=sn
					btn.BackgroundColor3=Color3.fromRGB(35,45,35)
					local sb=btn:FindFirstChild("SelectBar") if sb then sb.Size=UDim2.new(0,4,0,28) end
					local lb=btn:FindFirstChildOfClass("TextLabel") if lb then lb.TextColor3=Color3.fromRGB(255,255,255) end
					local st=btn:FindFirstChildOfClass("UIStroke") if st then st.Color=Color3.fromRGB(80,200,80) end
				end
			end
		end
	end

	rsb.MouseButton1Click:Connect(function()
		if autoPlantEnabled then return end
		rsb.Text="..." rsb.BackgroundColor3=Color3.fromRGB(80,80,80) task.wait(0.5) refreshPlantSeeds(false)
		rsb.Text="✓ Done!" rsb.BackgroundColor3=Color3.fromRGB(80,200,80) task.wait(1)
		rsb.Text="🔄 Refresh" rsb.BackgroundColor3=Color3.fromRGB(60,120,200)
	end)

	refreshPlantSeeds(false)

	task.spawn(function()
		while ScreenGui and ScreenGui.Parent do task.wait(1)
			if PlantPage.Visible and not autoPlantEnabled then refreshPlantSeeds(true) end
		end
	end)

	sw.MouseButton1Click:Connect(function()
		if not selectedPlantSeed and not autoPlantEnabled then
			PlantToggleDesc.Text="Please select a seed first!" PlantToggleDesc.TextColor3=Color3.fromRGB(255,100,100)
			task.wait(1) PlantToggleDesc.Text="Select a seed from backpack" PlantToggleDesc.TextColor3=Color3.fromRGB(100,100,100) return
		end
		if not currentPlot and not autoPlantEnabled then
			PlantToggleDesc.Text="Please refresh plot first!" PlantToggleDesc.TextColor3=Color3.fromRGB(255,100,100)
			task.wait(1) PlantToggleDesc.Text="Select a seed from backpack" PlantToggleDesc.TextColor3=Color3.fromRGB(100,100,100) return
		end
		autoPlantEnabled = not autoPlantEnabled
		if autoPlantEnabled then equipSeed(selectedPlantSeed) toggleOn(sw,kn)
			statusOn(PlantStatusDot,PlantStatusLabel,"Planting - "..(selectedPlantSeed or "None")..(currentPlot and (" @ "..currentPlot) or ""),Color3.fromRGB(80,200,80))
		else toggleOff(sw,kn) statusOff(PlantStatusDot,PlantStatusLabel) end
	end)
end

