-- PULSE ANIMATIONS
-- ══════════════════════════════════════════
local function pulseLoop(condition, dot, c1, c2)
	task.spawn(function()
		while ScreenGui and ScreenGui.Parent do
			if condition() then
				TweenService:Create(dot,TweenInfo.new(0.5),{BackgroundColor3=c1}):Play() task.wait(0.5)
				TweenService:Create(dot,TweenInfo.new(0.5),{BackgroundColor3=c2}):Play() task.wait(0.5)
			else task.wait(0.3) end
		end
	end)
end

