-- ══════════════════════════════════════════
local DupePage = createPage("DupePage", false)

do
	-- Helper: get the Shillings IntValue safely
	local function getShillingsObj()
		local ls = player:FindFirstChild("leaderstats")
		if ls then return ls:FindFirstChild("Shillings") end
		return nil
	end

	-- ── Header card ─────────────────────────
	local hc = createCard(DupePage, 75, 1)
	local hi = Instance.new("TextLabel") hi.Size=UDim2.new(0,35,0,35) hi.Position=UDim2.new(0,12,0,12)
	hi.BackgroundTransparency=1 hi.Text="💎" hi.TextSize=28 hi.Parent=hc
	local ht = Instance.new("TextLabel") ht.Size=UDim2.new(1,-60,0,24) ht.Position=UDim2.new(0,50,0,10)
	ht.BackgroundTransparency=1 ht.Text="Dupe Money" ht.TextColor3=Color3.fromRGB(255,255,255)
	ht.Font=Enum.Font.GothamBold ht.TextSize=isMobile and 16 or 18 ht.TextXAlignment=Enum.TextXAlignment.Left ht.Parent=hc
	local hd = Instance.new("TextLabel") hd.Size=UDim2.new(1,-60,0,18) hd.Position=UDim2.new(0,50,0,36)
	hd.BackgroundTransparency=1 hd.Text="Set your Shillings to any value"
	hd.TextColor3=Color3.fromRGB(100,100,100) hd.Font=Enum.Font.GothamMedium
	hd.TextSize=isMobile and 10 or 12 hd.TextXAlignment=Enum.TextXAlignment.Left hd.Parent=hc

	-- ── Current balance display card ────────
	local bc = createCard(DupePage, 65, 2)
	local bi = Instance.new("TextLabel") bi.Size=UDim2.new(0,35,1,0) bi.Position=UDim2.new(0,12,0,0)
	bi.BackgroundTransparency=1 bi.Text="💰" bi.TextSize=24 bi.Parent=bc
	local bt = Instance.new("TextLabel") bt.Size=UDim2.new(1,-60,0,20) bt.Position=UDim2.new(0,50,0,10)
	bt.BackgroundTransparency=1 bt.Text="Current Shillings" bt.TextColor3=Color3.fromRGB(180,180,180)
	bt.Font=Enum.Font.GothamMedium bt.TextSize=isMobile and 10 or 12 bt.TextXAlignment=Enum.TextXAlignment.Left bt.Parent=bc
	local BalanceLabel = Instance.new("TextLabel") BalanceLabel.Size=UDim2.new(1,-60,0,24)
	BalanceLabel.Position=UDim2.new(0,50,0,32) BalanceLabel.BackgroundTransparency=1
	BalanceLabel.Text="Loading..." BalanceLabel.TextColor3=Color3.fromRGB(255,200,80)
	BalanceLabel.Font=Enum.Font.GothamBold BalanceLabel.TextSize=isMobile and 18 or 22
	BalanceLabel.TextXAlignment=Enum.TextXAlignment.Left BalanceLabel.Parent=bc

	-- Update balance label live
	task.spawn(function()
		while ScreenGui and ScreenGui.Parent do
			local sh = getShillingsObj()
			BalanceLabel.Text = sh and tostring(sh.Value) or "N/A"
			task.wait(0.5)
		end
	end)

	-- ── Amount input card ───────────────────
	local ic2 = createCard(DupePage, 95, 3)
	local il = Instance.new("TextLabel") il.Size=UDim2.new(1,-20,0,22) il.Position=UDim2.new(0,12,0,8)
	il.BackgroundTransparency=1 il.Text="SET AMOUNT" il.TextColor3=Color3.fromRGB(80,80,80)
	il.Font=Enum.Font.GothamBold il.TextSize=isMobile and 10 or 12 il.TextXAlignment=Enum.TextXAlignment.Left il.Parent=ic2

	local inputBox = Instance.new("TextBox") inputBox.Size=UDim2.new(1,-24,0,36)
	inputBox.Position=UDim2.new(0,12,0,32) inputBox.BackgroundColor3=Color3.fromRGB(35,35,35)
	inputBox.BorderSizePixel=0 inputBox.Text="" inputBox.PlaceholderText="Enter amount (e.g. 1000000)"
	inputBox.TextColor3=Color3.fromRGB(255,255,255) inputBox.PlaceholderColor3=Color3.fromRGB(80,80,80)
	inputBox.Font=Enum.Font.GothamBold inputBox.TextSize=isMobile and 13 or 15
	inputBox.ClearTextOnFocus=false inputBox.Parent=ic2
	local ibcr=Instance.new("UICorner") ibcr.CornerRadius=UDim.new(0,8) ibcr.Parent=inputBox
	local ibst=Instance.new("UIStroke") ibst.Color=Color3.fromRGB(60,60,60) ibst.Thickness=1 ibst.Parent=inputBox
	inputBox:GetPropertyChangedSignal("Text"):Connect(function()
		-- Strip non-digits while typing
		local clean = inputBox.Text:gsub("[^%d]", "")
		if clean ~= inputBox.Text then inputBox.Text = clean end
		TweenService:Create(ibst,TweenInfo.new(0.15),{Color=Color3.fromRGB(100,180,100)}):Play()
	end)

	local StatusLabel2 = Instance.new("TextLabel") StatusLabel2.Size=UDim2.new(1,-24,0,18)
	StatusLabel2.Position=UDim2.new(0,12,0,72) StatusLabel2.BackgroundTransparency=1
	StatusLabel2.Text="" StatusLabel2.TextColor3=Color3.fromRGB(120,120,120)
	StatusLabel2.Font=Enum.Font.GothamMedium StatusLabel2.TextSize=isMobile and 9 or 11
	StatusLabel2.TextXAlignment=Enum.TextXAlignment.Left StatusLabel2.Parent=ic2

	-- ── Quick amount buttons ─────────────────
	local qc = createCard(DupePage, 105, 4)
	local ql = Instance.new("TextLabel") ql.Size=UDim2.new(1,-20,0,22) ql.Position=UDim2.new(0,12,0,8)
	ql.BackgroundTransparency=1 ql.Text="QUICK SET" ql.TextColor3=Color3.fromRGB(80,80,80)
	ql.Font=Enum.Font.GothamBold ql.TextSize=isMobile and 10 or 12 ql.TextXAlignment=Enum.TextXAlignment.Left ql.Parent=qc

	local QUICK_AMOUNTS = {
		{Label="1K",   Value=1000},
		{Label="10K",  Value=10000},
		{Label="100K", Value=100000},
		{Label="1M",   Value=1000000},
		{Label="10M",  Value=10000000},
		{Label="MAX",  Value=2147483647},
	}

	local qgFrame = Instance.new("Frame") qgFrame.Size=UDim2.new(1,-24,0,60) qgFrame.Position=UDim2.new(0,12,0,32)
	qgFrame.BackgroundTransparency=1 qgFrame.Parent=qc
	local qgl = Instance.new("UIGridLayout") qgl.CellSize=UDim2.new(1/3,-4,0,26)
	qgl.CellPadding=UDim2.new(0,4,0,4) qgl.SortOrder=Enum.SortOrder.LayoutOrder qgl.Parent=qgFrame

	for i, qa in ipairs(QUICK_AMOUNTS) do
		local qb = Instance.new("TextButton") qb.Size=UDim2.new(1,0,0,26)
		qb.BackgroundColor3=Color3.fromRGB(40,40,40) qb.BorderSizePixel=0
		qb.Text=qa.Label qb.TextColor3=Color3.fromRGB(180,180,180)
		qb.Font=Enum.Font.GothamBold qb.TextSize=isMobile and 11 or 13
		qb.LayoutOrder=i qb.Parent=qgFrame
		local qbcr=Instance.new("UICorner") qbcr.CornerRadius=UDim.new(0,6) qbcr.Parent=qb
		qb.MouseButton1Click:Connect(function()
			inputBox.Text = tostring(qa.Value)
			TweenService:Create(qb,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(60,100,60)}):Play()
			task.wait(0.2) TweenService:Create(qb,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(40,40,40)}):Play()
		end)
	end

	-- ── Set button card ───────────────────────
	local sc2 = createCard(DupePage, 58, 5)
	local setBtn = Instance.new("TextButton") setBtn.Size=UDim2.new(1,-24,0,36)
	setBtn.Position=UDim2.new(0,12,0,11) setBtn.BackgroundColor3=Color3.fromRGB(80,200,80)
	setBtn.BorderSizePixel=0 setBtn.Text="💎 Set Shillings"
	setBtn.TextColor3=Color3.fromRGB(255,255,255) setBtn.Font=Enum.Font.GothamBold
	setBtn.TextSize=isMobile and 13 or 15 setBtn.Parent=sc2
	local setcr=Instance.new("UICorner") setcr.CornerRadius=UDim.new(0,8) setcr.Parent=setBtn

	setBtn.MouseButton1Click:Connect(function()
		local raw = inputBox.Text
		local amount = tonumber(raw)

		if not amount then
			StatusLabel2.Text = "❌ Enter a valid number first"
			StatusLabel2.TextColor3 = Color3.fromRGB(255,80,80)
			return
		end

		-- Clamp to int32 max (Roblox IntValue limit)
		amount = math.clamp(math.floor(amount), 0, 2147483647)

		local sh = getShillingsObj()
		if not sh then
			StatusLabel2.Text = "❌ leaderstats.Shillings not found!"
			StatusLabel2.TextColor3 = Color3.fromRGB(255,80,80)
			showNotification("❌ Shillings value not found in leaderstats", Color3.fromRGB(255,80,80), 4)
			return
		end

		local prevValue = sh.Value

		-- Set the value directly on the client-side IntValue
		local ok, err = pcall(function()
			sh.Value = amount
		end)

		if ok then
			StatusLabel2.Text = "✓ Set to " .. tostring(amount) .. " (was " .. tostring(prevValue) .. ")"
			StatusLabel2.TextColor3 = Color3.fromRGB(80,200,80)
			TweenService:Create(setBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(50,150,50)}):Play()
			showNotification("💎 Shillings set to " .. tostring(amount), Color3.fromRGB(255,200,80), 3)
			task.wait(1.5)
			TweenService:Create(setBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,200,80)}):Play()
		else
			StatusLabel2.Text = "❌ Failed: " .. tostring(err)
			StatusLabel2.TextColor3 = Color3.fromRGB(255,80,80)
			showNotification("❌ Could not set Shillings: " .. tostring(err), Color3.fromRGB(255,80,80), 5)
		end
	end)

	-- ── Add/subtract card ────────────────────
	local ac = createCard(DupePage, 80, 6)
	local al = Instance.new("TextLabel") al.Size=UDim2.new(1,-20,0,22) al.Position=UDim2.new(0,12,0,8)
	al.BackgroundTransparency=1 al.Text="ADD / SUBTRACT" al.TextColor3=Color3.fromRGB(80,80,80)
	al.Font=Enum.Font.GothamBold al.TextSize=isMobile and 10 or 12 al.TextXAlignment=Enum.TextXAlignment.Left al.Parent=ac

	local addBtn = Instance.new("TextButton") addBtn.Size=UDim2.new(0.48,0,0,32) addBtn.Position=UDim2.new(0,12,0,34)
	addBtn.BackgroundColor3=Color3.fromRGB(60,140,220) addBtn.BorderSizePixel=0 addBtn.Text="＋ Add Amount"
	addBtn.TextColor3=Color3.fromRGB(255,255,255) addBtn.Font=Enum.Font.GothamBold addBtn.TextSize=isMobile and 11 or 13 addBtn.Parent=ac
	local adcr=Instance.new("UICorner") adcr.CornerRadius=UDim.new(0,6) adcr.Parent=addBtn

	local subBtn = Instance.new("TextButton") subBtn.Size=UDim2.new(0.48,-12,0,32) subBtn.Position=UDim2.new(0.5,6,0,34)
	subBtn.BackgroundColor3=Color3.fromRGB(200,80,80) subBtn.BorderSizePixel=0 subBtn.Text="－ Subtract"
	subBtn.TextColor3=Color3.fromRGB(255,255,255) subBtn.Font=Enum.Font.GothamBold subBtn.TextSize=isMobile and 11 or 13 subBtn.Parent=ac
	local subcr=Instance.new("UICorner") subcr.CornerRadius=UDim.new(0,6) subcr.Parent=subBtn

	local function adjustShillings(delta)
		local raw = inputBox.Text
		local amount = tonumber(raw)
		if not amount then
			StatusLabel2.Text = "❌ Enter an amount above first"
			StatusLabel2.TextColor3 = Color3.fromRGB(255,80,80)
			return
		end
		local sh = getShillingsObj()
		if not sh then
			StatusLabel2.Text = "❌ leaderstats.Shillings not found!"
			StatusLabel2.TextColor3 = Color3.fromRGB(255,80,80)
			return
		end
		local newVal = math.clamp(sh.Value + delta * math.floor(amount), 0, 2147483647)
		local ok, err = pcall(function() sh.Value = newVal end)
		if ok then
			local sign = delta > 0 and "+" or "-"
			StatusLabel2.Text = sign .. tostring(math.floor(amount)) .. " → now " .. tostring(newVal)
			StatusLabel2.TextColor3 = delta > 0 and Color3.fromRGB(80,200,80) or Color3.fromRGB(255,150,80)
		else
			StatusLabel2.Text = "❌ " .. tostring(err)
			StatusLabel2.TextColor3 = Color3.fromRGB(255,80,80)
		end
	end

	addBtn.MouseButton1Click:Connect(function() adjustShillings(1) end)
	subBtn.MouseButton1Click:Connect(function() adjustShillings(-1) end)

	-- ── Info card ─────────────────────────────
	local nc = createCard(DupePage, 85, 7)
	local nt = Instance.new("TextLabel") nt.Size=UDim2.new(1,-20,0,22) nt.Position=UDim2.new(0,12,0,10)
	nt.BackgroundTransparency=1 nt.Text="ℹ️ How it works" nt.TextColor3=Color3.fromRGB(255,255,255)
	nt.Font=Enum.Font.GothamBold nt.TextSize=S.CF nt.TextXAlignment=Enum.TextXAlignment.Left nt.Parent=nc
	local nd = Instance.new("TextLabel") nd.Size=UDim2.new(1,-24,0,50) nd.Position=UDim2.new(0,12,0,34)
	nd.BackgroundTransparency=1 nd.TextColor3=Color3.fromRGB(120,120,120) nd.Font=Enum.Font.GothamMedium
	nd.TextSize=isMobile and 10 or 11 nd.TextXAlignment=Enum.TextXAlignment.Left nd.TextYAlignment=Enum.TextYAlignment.Top
	nd.Text="• Sets leaderstats.Shillings directly\n• Max value: 2,147,483,647 (int32)\n• Use Quick Set buttons for common amounts"
	nd.Parent=nc
end

-- ══════════════════════════════════════════
-- MISC PAGE
-- ══════════════════════════════════════════
local MiscPage = createPage("MiscPage", false)

do
	local CODES = {
		"RELEASE", "DAWN", "DAWNFRUIT", "GIFT",
		"358", "THANKYOU", "ADMIN"
	}

	-- ── Header card ─────────────────────────
	local hc = createCard(MiscPage, 75, 1)
	local hi = Instance.new("TextLabel") hi.Size=UDim2.new(0,35,0,35) hi.Position=UDim2.new(0,12,0,12)
	hi.BackgroundTransparency=1 hi.Text="🔧" hi.TextSize=28 hi.Parent=hc
	local ht = Instance.new("TextLabel") ht.Size=UDim2.new(1,-60,0,24) ht.Position=UDim2.new(0,50,0,10)
	ht.BackgroundTransparency=1 ht.Text="Miscellaneous" ht.TextColor3=Color3.fromRGB(255,255,255)
	ht.Font=Enum.Font.GothamBold ht.TextSize=isMobile and 16 or 18 ht.TextXAlignment=Enum.TextXAlignment.Left ht.Parent=hc
	local hd = Instance.new("TextLabel") hd.Size=UDim2.new(1,-60,0,18) hd.Position=UDim2.new(0,50,0,36)
	hd.BackgroundTransparency=1 hd.Text="Redeem codes & extra tools"
	hd.TextColor3=Color3.fromRGB(100,100,100) hd.Font=Enum.Font.GothamMedium
	hd.TextSize=isMobile and 10 or 12 hd.TextXAlignment=Enum.TextXAlignment.Left hd.Parent=hc

	-- ── Redeem Codes section ────────────────
	local rc = createCard(MiscPage, 50, 2)
	local ri = Instance.new("TextLabel") ri.Size=UDim2.new(0,28,1,0) ri.Position=UDim2.new(0,10,0,0)
	ri.BackgroundTransparency=1 ri.Text="🎁" ri.TextSize=20 ri.Parent=rc
	local rl = Instance.new("TextLabel") rl.Size=UDim2.new(1,-55,0,22) rl.Position=UDim2.new(0,42,0,8)
	rl.BackgroundTransparency=1 rl.Text="Redeem Codes" rl.TextColor3=Color3.fromRGB(255,255,255)
	rl.Font=Enum.Font.GothamBold rl.TextSize=isMobile and 14 or 16 rl.TextXAlignment=Enum.TextXAlignment.Left rl.Parent=rc
	local rsub = Instance.new("TextLabel") rsub.Size=UDim2.new(1,-55,0,16) rsub.Position=UDim2.new(0,42,0,30)
	rsub.BackgroundTransparency=1 rsub.Text=tostring(#CODES).." codes available"
	rsub.TextColor3=Color3.fromRGB(100,100,100) rsub.Font=Enum.Font.GothamMedium
	rsub.TextSize=isMobile and 9 or 11 rsub.TextXAlignment=Enum.TextXAlignment.Left rsub.Parent=rc

	-- Status bar
	local sc = createCard(MiscPage, S.SCH, 3)
	local CodeStatusDot = Instance.new("Frame") CodeStatusDot.Size=UDim2.new(0,12,0,12)
	CodeStatusDot.Position=UDim2.new(0,12,0.5,-6) CodeStatusDot.BackgroundColor3=Color3.fromRGB(100,100,100)
	CodeStatusDot.BorderSizePixel=0 CodeStatusDot.Parent=sc
	local dcr=Instance.new("UICorner") dcr.CornerRadius=UDim.new(1,0) dcr.Parent=CodeStatusDot
	local CodeStatusLabel = Instance.new("TextLabel") CodeStatusLabel.Size=UDim2.new(1,-40,1,0)
	CodeStatusLabel.Position=UDim2.new(0,35,0,0) CodeStatusLabel.BackgroundTransparency=1
	CodeStatusLabel.Text="Ready to redeem" CodeStatusLabel.TextColor3=Color3.fromRGB(100,100,100)
	CodeStatusLabel.Font=Enum.Font.GothamBold CodeStatusLabel.TextSize=S.CF
	CodeStatusLabel.TextXAlignment=Enum.TextXAlignment.Left CodeStatusLabel.Parent=sc

	-- Redeem all button
	local rac = createCard(MiscPage, 50, 4)
	local redeemAllBtn = Instance.new("TextButton") redeemAllBtn.Size=UDim2.new(1,-24,0,32)
	redeemAllBtn.Position=UDim2.new(0,12,0,9) redeemAllBtn.BackgroundColor3=Color3.fromRGB(80,200,80)
	redeemAllBtn.BorderSizePixel=0 redeemAllBtn.Text="🎁 Redeem All Codes"
	redeemAllBtn.TextColor3=Color3.fromRGB(255,255,255) redeemAllBtn.Font=Enum.Font.GothamBold
	redeemAllBtn.TextSize=isMobile and 13 or 15 redeemAllBtn.Parent=rac
	local racr=Instance.new("UICorner") racr.CornerRadius=UDim.new(0,8) racr.Parent=redeemAllBtn

	-- Per-code cards grid
	local codeListHeader = Instance.new("TextLabel") codeListHeader.Size=UDim2.new(1,0,0,25)
	codeListHeader.BackgroundTransparency=1 codeListHeader.Text="INDIVIDUAL CODES"
	codeListHeader.TextColor3=Color3.fromRGB(80,80,80) codeListHeader.Font=Enum.Font.GothamBold
	codeListHeader.TextSize=isMobile and 10 or 12 codeListHeader.TextXAlignment=Enum.TextXAlignment.Left
	codeListHeader.LayoutOrder=5 codeListHeader.Parent=MiscPage

	-- Track result per code: nil=untried, true=success, false=failed
	local codeResults = {}
	local codeButtons = {}  -- [codeName] = {btn, dot, label}

	local function redeemCode(codeName)
		local RedeemRemote = ReplicatedStorage:FindFirstChild("RemoteEvents")
						and ReplicatedStorage.RemoteEvents:FindFirstChild("RedeemCode")
		if not RedeemRemote then
			return false, "Remote not found"
		end
		local ok, result, reason = pcall(function()
			return RedeemRemote:InvokeServer(codeName)
		end)
		if not ok then
			return false, tostring(result)
		end
		-- Server returns: true on success, false + reason on fail
		if result == true or (type(result) == "table" and result.Success) then
			return true, "Redeemed!"
		elseif result == false then
			return false, tostring(reason or "Already redeemed or invalid")
		else
			-- Some servers return a string message directly
			local msg = tostring(result or reason or "Unknown")
			local isSuccess = msg:lower():find("success") or msg:lower():find("redeem") or msg:lower():find("reward")
			return isSuccess and true or false, msg
		end
	end

	local function updateCodeButton(codeName, state, msg)
		-- state: "idle" | "loading" | "success" | "failed"
		local refs = codeButtons[codeName]
		if not refs then return end
		local btn, dot, lbl = refs.btn, refs.dot, refs.lbl
		if state == "loading" then
			TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(60,60,60)}):Play()
			TweenService:Create(dot,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(200,180,60)}):Play()
			lbl.Text="Redeeming..."
			lbl.TextColor3=Color3.fromRGB(200,180,60)
			btn.Text="⏳"
		elseif state == "success" then
			TweenService:Create(btn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(40,120,40)}):Play()
			TweenService:Create(dot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,200,80)}):Play()
			lbl.Text="✓ " .. (msg or "Redeemed!")
			lbl.TextColor3=Color3.fromRGB(80,200,80)
			btn.Text="✓"
			btn.Active=false
		elseif state == "failed" then
			TweenService:Create(btn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(60,30,30)}):Play()
			TweenService:Create(dot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(200,80,80)}):Play()
			lbl.Text="✗ " .. (msg or "Failed")
			lbl.TextColor3=Color3.fromRGB(200,80,80)
			btn.Text="↺"
			btn.Active=true
		else -- idle
			TweenService:Create(btn,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(60,140,220)}):Play()
			TweenService:Create(dot,TweenInfo.new(0.15),{BackgroundColor3=Color3.fromRGB(100,100,100)}):Play()
			lbl.Text=codeName
			lbl.TextColor3=Color3.fromRGB(180,180,180)
			btn.Text="Claim"
			btn.Active=true
		end
	end

	for i, codeName in ipairs(CODES) do
		local card = createCard(MiscPage, 50, 5 + i)
		-- Status dot
		local dot = Instance.new("Frame") dot.Size=UDim2.new(0,10,0,10)
		dot.Position=UDim2.new(0,12,0.5,-5) dot.BackgroundColor3=Color3.fromRGB(100,100,100)
		dot.BorderSizePixel=0 dot.Parent=card
		local dotcr=Instance.new("UICorner") dotcr.CornerRadius=UDim.new(1,0) dotcr.Parent=dot
		-- Code name label
		local lbl = Instance.new("TextLabel") lbl.Size=UDim2.new(1,-(isMobile and 130 or 150),1,0)
		lbl.Position=UDim2.new(0,30,0,0) lbl.BackgroundTransparency=1
		lbl.Text=codeName lbl.TextColor3=Color3.fromRGB(180,180,180)
		lbl.Font=Enum.Font.GothamBold lbl.TextSize=isMobile and 11 or 13
		lbl.TextXAlignment=Enum.TextXAlignment.Left lbl.TextTruncate=Enum.TextTruncate.AtEnd lbl.Parent=card
		-- Claim button
		local bw = isMobile and 70 or 85
		local btn = Instance.new("TextButton") btn.Size=UDim2.new(0,bw,0,30)
		btn.Position=UDim2.new(1,-(bw+10),0.5,-15)
		btn.BackgroundColor3=Color3.fromRGB(60,140,220) btn.BorderSizePixel=0
		btn.Text="Claim" btn.TextColor3=Color3.fromRGB(255,255,255)
		btn.Font=Enum.Font.GothamBold btn.TextSize=isMobile and 11 or 13 btn.Parent=card
		local btncr=Instance.new("UICorner") btncr.CornerRadius=UDim.new(0,6) btncr.Parent=btn

		codeButtons[codeName] = {btn=btn, dot=dot, lbl=lbl}

		btn.MouseButton1Click:Connect(function()
			if not btn.Active then return end
			updateCodeButton(codeName, "loading", nil)
			CodeStatusLabel.Text = "Redeeming: " .. codeName
			CodeStatusLabel.TextColor3 = Color3.fromRGB(200,180,60)
			TweenService:Create(CodeStatusDot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(200,180,60)}):Play()
			task.spawn(function()
				local success, msg = redeemCode(codeName)
				codeResults[codeName] = success
				if success then
					updateCodeButton(codeName, "success", msg)
					CodeStatusLabel.Text = "✓ " .. codeName .. " redeemed!"
					CodeStatusLabel.TextColor3 = Color3.fromRGB(80,200,80)
					TweenService:Create(CodeStatusDot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,200,80)}):Play()
					showNotification("🎁 Code redeemed: " .. codeName, Color3.fromRGB(80,200,80), 3)
				else
					updateCodeButton(codeName, "failed", msg)
					CodeStatusLabel.Text = "✗ " .. codeName .. ": " .. tostring(msg)
					CodeStatusLabel.TextColor3 = Color3.fromRGB(200,80,80)
					TweenService:Create(CodeStatusDot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(200,80,80)}):Play()
				end
			end)
		end)
	end

	-- Redeem All logic
	redeemAllBtn.MouseButton1Click:Connect(function()
		redeemAllBtn.Active = false
		redeemAllBtn.Text = "⏳ Redeeming..."
		TweenService:Create(redeemAllBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,80,80)}):Play()

		local succeeded, failed = 0, 0

		for i, codeName in ipairs(CODES) do
			-- Skip codes already successfully redeemed this session
			if codeResults[codeName] == true then
				succeeded = succeeded + 1
				continue
			end

			updateCodeButton(codeName, "loading", nil)
			CodeStatusLabel.Text = "Redeeming: " .. codeName .. " (" .. i .. "/" .. #CODES .. ")"
			CodeStatusLabel.TextColor3 = Color3.fromRGB(200,180,60)
			TweenService:Create(CodeStatusDot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(200,180,60)}):Play()
			redeemAllBtn.Text = "⏳ " .. codeName .. "..."

			local success, msg = redeemCode(codeName)
			codeResults[codeName] = success
			if success then
				succeeded = succeeded + 1
				updateCodeButton(codeName, "success", msg)
			else
				failed = failed + 1
				updateCodeButton(codeName, "failed", msg)
			end

			task.wait(0.4) -- small delay between codes to avoid rate limiting
		end

		-- Final summary
		local summaryColor = failed == 0 and Color3.fromRGB(80,200,80) or Color3.fromRGB(255,180,50)
		local summaryText = "✓ " .. succeeded .. " redeemed"
		if failed > 0 then summaryText = summaryText .. "  ✗ " .. failed .. " failed" end
		CodeStatusLabel.Text = summaryText
		CodeStatusLabel.TextColor3 = summaryColor
		TweenService:Create(CodeStatusDot,TweenInfo.new(0.2),{BackgroundColor3=summaryColor}):Play()
		showNotification("🎁 Codes done: " .. summaryText, summaryColor, 4)

		task.wait(1.5)
		redeemAllBtn.Active = true
		redeemAllBtn.Text = "🎁 Redeem All Codes"
		TweenService:Create(redeemAllBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(80,200,80)}):Play()
	end)
end

