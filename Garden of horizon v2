				TweenService:Create(GearStatusDot,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(200,80,80)}):Play()
			end

			-- Update stock label for this item
			local s = GearStockData[gi.Name]
			if s ~= nil then
				stockL.Text = s > 0 and ("Stock: " .. s .. "x") or "Stock: OUT"
				stockL.TextColor3 = s > 0 and Color3.fromRGB(80,200,80) or Color3.fromRGB(255,80,80)
