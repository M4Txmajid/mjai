local function detectPlot()
	local r = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	if not r then return nil end
	local pp = r.Position
	local cp, cd = nil, math.huge
	for pn, c in pairs(PlotCenters) do
		local d = (c - pp).Magnitude
		if d < cd then cd = d; cp = pn end
	end
	return cd <= 150 and cp or nil
end

local function getRandomPositionFromPlot(plotName)
	local pos = PlotData[plotName]
	if not pos then return nil end
	local rp = pos[math.random(1, #pos)]
	return CFrame.new(rp.X + (math.random()-0.5)*10, rp.Y + 3, rp.Z + (math.random()-0.5)*10)
end

local function equipSeed(seedName)
	local bp = player.Backpack
	local ch = player.Character
	if not bp or not ch then return false end
	if ch:FindFirstChild(seedName) then return true end
	local t = bp:FindFirstChild(seedName)
	if t and t:IsA("Tool") then
		local h = ch:FindFirstChildOfClass("Humanoid")
		if h then h:EquipTool(t) return true end
	end
	return false
end

local function getAllSeeds()
	local s = {}
	local function check(parent)
		if not parent then return end
		for _, item in pairs(parent:GetChildren()) do
			if item:IsA("Tool") and item.Name:find("Seed") and not table.find(s, item.Name) then
				table.insert(s, item.Name)
			end
		end
	end
	check(player.Backpack)
	check(player.Character)
	return s
end

local function makeAllPromptsInstant()
	if not ClientPlants then return end
	for _, d in pairs(ClientPlants:GetDescendants()) do
		if d:IsA("ProximityPrompt") then
			pcall(function() d.HoldDuration=0 d.MaxActivationDistance=100 d.RequiresLineOfSight=false d.Enabled=true end)
		end
	end
end

local function getAllHarvestablePlants()
	local plants = {}
	if ClientPlants then
		for _, d in pairs(ClientPlants:GetDescendants()) do
			if d:IsA("ProximityPrompt") then
				local p = d.Parent
				if p and p:IsA("BasePart") then
					table.insert(plants, {Part=p, Prompt=d})
				elseif p then
					local bp = p:FindFirstChildWhichIsA("BasePart", true)
					if bp then table.insert(plants, {Part=bp, Prompt=d})
					else
						local cur = p
						while cur and cur ~= ClientPlants do
							if cur:IsA("BasePart") then table.insert(plants, {Part=cur, Prompt=d}) break end
							local f = cur:FindFirstChildWhichIsA("BasePart", true)
							if f then table.insert(plants, {Part=f, Prompt=d}) break end
							cur = cur.Parent
						end
					end
				end
			end
		end
	end
	return plants
end

local function firePrompt(prompt)
	-- Method 1: executor-level bypass (works on all platforms, best option)
	pcall(function() if fireproximityprompt then fireproximityprompt(prompt) end end)
	-- Method 2: direct InputHold API (works on mobile & PC)
	pcall(function() prompt:InputHoldBegin() task.wait(0.05) prompt:InputHoldEnd() end)
	if isMobile then
		-- Method 3 (mobile): touch event on the prompt's parent part
		pcall(function()
			local part = prompt.Parent
			if part and part:IsA("BasePart") then
				VIM:SendMouseButtonEvent(part.Position.X, part.Position.Y, 0, true, game)
				task.wait(0.05)
				VIM:SendMouseButtonEvent(part.Position.X, part.Position.Y, 0, false, game)
			end
		end)
	else
		-- Method 3 (PC): keyboard E key
		pcall(function()
			VIM:SendKeyEvent(true,Enum.KeyCode.E,false,game)
			task.wait(0.05)
			VIM:SendKeyEvent(false,Enum.KeyCode.E,false,game)
		end)
	end
end

