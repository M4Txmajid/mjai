-- DRAG (fixed: uses position delta only, never AbsolutePosition)
local function wireDrag(h)
	h.InputBegan:Connect(function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
			if dragging then return end
			dragging = true
			activeTouchId = i
			local startX = root.Position.X.Offset
			local startY = root.Position.Y.Offset
			local startInputX = i.Position.X
			local startInputY = i.Position.Y
			local conn
			conn = UIS.InputChanged:Connect(function(m)
				if not dragging then conn:Disconnect() return end
				if m.UserInputType ~= Enum.UserInputType.MouseMovement and m.UserInputType ~= Enum.UserInputType.Touch then return end
				local nx = startX + (m.Position.X - startInputX)
				local ny = startY + (m.Position.Y - startInputY)
				root.Position = UDim2.new(0, nx, 0, ny)
				shadow.Position = UDim2.new(0, nx - 4, 0, ny + 4)
			end)
		end
	end)
	h.InputEnded:Connect(function(i)
		if i == activeTouchId or i.UserInputType == Enum.UserInputType.MouseButton1 then
			dragging = false
			activeTouchId = nil
		end
	end)
end

UIS.InputEnded:Connect(function(i)
	if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
		dragging = false
		activeSlider = nil
		activeTouchId = nil
	end
end)

UIS.InputChanged:Connect(function(i)
	if activeSlider and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then
		local s = activeSlider
		local mx = i.Position.X - s.track.AbsolutePosition.X
		local p = math.clamp(mx / s.track.AbsoluteSize.X, 0, 1)
		local v = math.floor(s.minV + p * (s.maxV - s.minV))
		s.fill.Size = UDim2.new(p, 0, 1, 0)
		s.thumb.Position = UDim2.new(p, 0, 0.5, 0)
		s.badge.Text = tostring(v)
		if s.cb then s.cb(v) end
	end
end)

