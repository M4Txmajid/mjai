-- DRAG — only wired on header/brand, won't conflict with content taps
local function wireDrag(h)
	h.InputBegan:Connect(function(i)
		if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
			if dragging then return end
			dragging=true; activeTouchId=i
			local sx=root.Position.X.Offset; local sy=root.Position.Y.Offset
			local ix=i.Position.X; local iy=i.Position.Y
			local conn; conn=UIS.InputChanged:Connect(function(m)
				if not dragging then conn:Disconnect(); return end
				if m.UserInputType~=Enum.UserInputType.MouseMovement and m.UserInputType~=Enum.UserInputType.Touch then return end
				local nx=sx+(m.Position.X-ix); local ny=sy+(m.Position.Y-iy)
				root.Position=UDim2.new(0,nx,0,ny); shadow.Position=UDim2.new(0,nx-4,0,ny+4)
			end)
		end
	end)
	h.InputEnded:Connect(function(i)
		if i==activeTouchId or i.UserInputType==Enum.UserInputType.MouseButton1 then
			dragging=false; activeTouchId=nil
		end
	end)
end

UIS.InputEnded:Connect(function(i)
	if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
