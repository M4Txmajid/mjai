local function addSlider(card,labelText,minV,maxV,defVal,order,cb)
	local row=newI("Frame",card,{Size=UDim2.new(1,0,0,38),BackgroundTransparency=1,LayoutOrder=order or 1})
	newI("TextLabel",row,{Size=UDim2.new(0,mob and 60 or 78,0,16),BackgroundTransparency=1,Text=labelText,Font=Enum.Font.Gotham,TextSize=mob and 10 or 12,TextColor3=ct.text2,TextXAlignment=Enum.TextXAlignment.Left})
	local nb=newI("TextLabel",row,{Size=UDim2.new(0,32,0,18),Position=UDim2.new(1,-32,0,-1),BackgroundColor3=ct.bg2,BorderSizePixel=0,Text=tostring(defVal),Font=Enum.Font.Code,TextSize=11,TextColor3=ct.text1}); corner(nb,4)
	local tOff=mob and 68 or 84
	local track=newI("Frame",row,{Name="Track",Size=UDim2.new(1,-tOff-38,0,mob and 8 or 5),Position=UDim2.new(0,tOff,0,mob and 4 or 6),BackgroundColor3=ct.bg3,BorderSizePixel=0}); corner(track,3)
	local p0=(defVal-minV)/(maxV-minV)
	local fill=newI("Frame",track,{Name="Fill",Size=UDim2.new(p0,0,1,0),BackgroundColor3=ct.acc1,BorderSizePixel=0}); corner(fill,3)
	local ts=mob and 20 or 14
	local thumb=newI("Frame",track,{Name="Thumb",Size=UDim2.new(0,ts,0,ts),AnchorPoint=Vector2.new(0.5,0.5),Position=UDim2.new(p0,0,0.5,0),BackgroundColor3=Color3.fromRGB(210,220,255),BorderSizePixel=0,ZIndex=5}); corner(thumb,mob and ts/2 or 4)
	local hit=newI("TextButton",track,{Size=UDim2.new(1,0,0,mob and 40 or 22),Position=UDim2.new(0,0,0.5,mob and -20 or -11),BackgroundTransparency=1,Text="",ZIndex=6})
	local function startSlide(pos)
		local p=math.clamp((pos.X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
		local v=math.floor(minV+p*(maxV-minV))
		fill.Size=UDim2.new(p,0,1,0); thumb.Position=UDim2.new(p,0,0.5,0); nb.Text=tostring(v)
		if cb then cb(v) end
		activeSlider={track=track,minV=minV,maxV=maxV,fill=fill,thumb=thumb,badge=nb,cb=cb}
	end
	hit.MouseButton1Down:Connect(function() startSlide(UIS:GetMouseLocation()) end)
	hit.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.Touch then startSlide(i.Position) end end)
end

