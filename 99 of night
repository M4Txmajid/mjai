-- APPLY THEME
applyTheme = function(t)
	ct=t
	tw(root,{BackgroundColor3=t.bg1},0.22); tw(rootStroke,{Color=t.acc1},0.22)
	tw(sidebar,{BackgroundColor3=t.bg0},0.22); tw(sideClip,{BackgroundColor3=t.bg0},0.22)
	shimCols[1]=t.acc1; shimCols[3]=t.acc2; shimCols[4]=t.acc4
	tw(brandLine,{BackgroundColor3=t.text3},0.22)
	tw(settingsNavBtn,{BackgroundColor3=t.surface,TextColor3=t.text0},0.22)
	tw(dot,{BackgroundColor3=t.acc4},0.22); dotBorder.Color=t.bg0
	tw(avatarFrame,{BackgroundColor3=t.acc1},0.22)
	tw(playerCard,{BackgroundColor3=t.surface},0.22)
	tw(statusLbl,{TextColor3=t.text0},0.22); tw(userNameLbl,{TextColor3=t.text2},0.22)
	tw(main,{BackgroundColor3=t.bg1},0.22)
	tw(headerBar,{BackgroundColor3=t.bg0},0.22); tw(headerDivLine,{BackgroundColor3=t.text3},0.22)
	tw(headerTitle,{TextColor3=t.text0},0.22)
	scrollFrame.ScrollBarImageColor3=t.acc1
	tw(floatBtn,{BackgroundColor3=t.acc1},0.22); floatStroke.Color=t.acc1
	tw(themesLabel,{TextColor3=t.text3},0.22); tw(displayLabel,{TextColor3=t.text3},0.22); tw(systemLabel,{TextColor3=t.text3},0.22)
	tw(displayCard,{BackgroundColor3=t.surface},0.22); dcs.Color=t.text3
	tw(systemCard,{BackgroundColor3=t.surface},0.22); scs.Color=t.text3
	for _,c in ipairs(displayCard:GetDescendants()) do
		if c:IsA("TextLabel") then tw(c,{TextColor3=c.Font==Enum.Font.Code and t.text1 or t.text2},0.22)
		elseif c:IsA("Frame") then
			if c.Name=="Fill" then tw(c,{BackgroundColor3=t.acc1},0.22)
			elseif c.Name=="Track" then tw(c,{BackgroundColor3=t.bg3},0.22)
			elseif c.Font==Enum.Font.Code then tw(c,{BackgroundColor3=t.bg2},0.22) end
		end
	end
	for _,c in ipairs(systemCard:GetDescendants()) do
		if c:IsA("TextLabel") then tw(c,{TextColor3=c.TextSize>=LS and t.text1 or t.text3},0.22)
		elseif c:IsA("Frame") then
			if c.Name=="Pill" then tw(c,{BackgroundColor3=c.BackgroundColor3~=ct.bg3 and t.acc1 or t.bg3},0.22)
			elseif c.Size==UDim2.new(1,0,0,1) then tw(c,{BackgroundColor3=t.text3},0.22) end
		end
	end
	for tn,cf in pairs(themeCardFrames) do
		local active=(tn==t.name)
		tw(cf.stroke,{Transparency=active and 0 or 0.6},0.22)
		cf.stroke.Thickness=active and 1.5 or 1
		cf.stroke.Color=active and t.acc1 or T[tn].text3
	end
end

