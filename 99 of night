-- safeTap: reliable mobile tap detection using UIS.InputEnded
local function safeTap(btn, cb)
	btn.MouseButton1Click:Connect(cb)
	if not mob then return end
	btn.InputBegan:Connect(function(i)
		if i.UserInputType ~= Enum.UserInputType.Touch then return end
		local startX, startY = i.Position.X, i.Position.Y
		local moved = false
		local mc = UIS.InputChanged:Connect(function(m)
			if m.UserInputType ~= Enum.UserInputType.Touch then return end
			if math.abs(m.Position.X - startX) > 20 or math.abs(m.Position.Y - startY) > 20 then
				moved = true
			end
		end)
		local ec; ec = UIS.InputEnded:Connect(function(e)
			if e.UserInputType ~= Enum.UserInputType.Touch then return end
			mc:Disconnect(); ec:Disconnect()
			if not moved then
				task.defer(cb)
			end
		end)
	end)
end

