-- LocalScript inside StarterPlayerScripts or StarterCharacterScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local flying = false
local flySpeed = 60
local bodyVelocity = nil
local bodyGyro = nil

-- GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlyGui"
screenGui.ResetOnSpawn = false
screenGui.IgnoreGuiInset = true
screenGui.Parent = player:WaitForChild("PlayerGui")

-- Fly toggle button
local flyBtn = Instance.new("TextButton")
flyBtn.Size = UDim2.new(0, 75, 0, 75)
flyBtn.Position = UDim2.new(1, -95, 1, -170)
flyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
flyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
flyBtn.Text = "FLY"
flyBtn.TextSize = 16
flyBtn.Font = Enum.Font.GothamBold
flyBtn.BorderSizePixel = 0
flyBtn.ZIndex = 10
flyBtn.Parent = screenGui

Instance.new("UICorner").CornerRadius = UDim.new(1, 0)
local fc = Instance.new("UICorner")
fc.CornerRadius = UDim.new(1, 0)
fc.Parent = flyBtn

-- Up button
local upBtn = Instance.new("TextButton")
upBtn.Size = UDim2.new(0, 60, 0, 60)
upBtn.Position = UDim2.new(1, -175, 1, -175)
upBtn.BackgroundColor3 = Color3.fromRGB(50, 120, 255)
upBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
upBtn.Text = "▲"
upBtn.TextSize = 24
upBtn.Font = Enum.Font.GothamBold
upBtn.BorderSizePixel = 0
upBtn.Visible = false
upBtn.ZIndex = 10
upBtn.Parent = screenGui

local uc = Instance.new("UICorner")
uc.CornerRadius = UDim.new(1, 0)
uc.Parent = upBtn

-- Down button
local downBtn = Instance.new("TextButton")
downBtn.Size = UDim2.new(0, 60, 0, 60)
downBtn.Position = UDim2.new(1, -175, 1, -105)
downBtn.BackgroundColor3 = Color3.fromRGB(255, 70, 70)
downBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
downBtn.Text = "▼"
downBtn.TextSize = 24
downBtn.Font = Enum.Font.GothamBold
downBtn.BorderSizePixel = 0
downBtn.Visible = false
downBtn.ZIndex = 10
downBtn.Parent = screenGui

local dc = Instance.new("UICorner")
dc.CornerRadius = UDim.new(1, 0)
dc.Parent = downBtn

local goingUp = false
local goingDown = false

-- Detect touch on up/down buttons properly
upBtn.MouseButton1Down:Connect(function() goingUp = true end)
upBtn.MouseButton1Up:Connect(function() goingUp = false end)
upBtn.MouseLeave:Connect(function() goingUp = false end)

downBtn.MouseButton1Down:Connect(function() goingDown = true end)
downBtn.MouseButton1Up:Connect(function() goingDown = false end)
downBtn.MouseLeave:Connect(function() goingDown = false end)

-- Also handle actual touch input for mobile
UserInputService.TouchEnded:Connect(function()
    goingUp = false
    goingDown = false
end)

local function startFly()
    flying = true
    flyBtn.BackgroundColor3 = Color3.fromRGB(40, 200, 90)
    flyBtn.Text = "LAND"
    upBtn.Visible = true
    downBtn.Visible = true

    humanoid.PlatformStand = true

    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.zero
    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVelocity.Parent = rootPart

    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bodyGyro.D = 150
    bodyGyro.P = 10000
    bodyGyro.Parent = rootPart
end

local function stopFly()
    flying = false
    flyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    flyBtn.Text = "FLY"
    upBtn.Visible = false
    downBtn.Visible = false
    goingUp = false
    goingDown = false

    humanoid.PlatformStand = false

    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

flyBtn.MouseButton1Click:Connect(function()
    if flying then stopFly() else startFly() end
end)

-- Main fly loop
RunService.Heartbeat:Connect(function()
    if not flying then return end
    if not rootPart or not bodyVelocity or not bodyGyro then return end

    local camera = workspace.CurrentCamera

    -- Use humanoid.MoveDirection which works with the on-screen joystick on mobile
    local moveVector = humanoid.MoveDirection
    local moveDir = Vector3.zero

    if moveVector.Magnitude > 0.01 then
        -- Move relative to camera direction so it feels natural
        local camYaw = CFrame.Angles(0, math.atan2(-camera.CFrame.LookVector.X, -camera.CFrame.LookVector.Z), 0)
        local localMove = camYaw * Vector3.new(moveVector.X, 0, moveVector.Z)
        moveDir = Vector3.new(localMove.X, 0, localMove.Z)
        if moveDir.Magnitude > 1 then
            moveDir = moveDir.Unit
        end
    end

    local verticalDir = Vector3.zero
    if goingUp then
        verticalDir = Vector3.new(0, 1, 0)
    elseif goingDown then
        verticalDir = Vector3.new(0, -1, 0)
    end

    local finalVelocity = moveDir * flySpeed + verticalDir * flySpeed

    bodyVelocity.Velocity = finalVelocity

    -- Rotate character to face movement direction smoothly
    if moveDir.Magnitude > 0.1 then
        bodyGyro.CFrame = CFrame.new(Vector3.zero, moveDir)
    end
end)

-- Respawn handler
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    rootPart = newChar:WaitForChild("HumanoidRootPart")
    flying = false
    bodyVelocity = nil
    bodyGyro = nil
    flyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    flyBtn.Text = "FLY"
    upBtn.Visible = false
    downBtn.Visible = false
end)
