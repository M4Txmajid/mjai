-- // CREATE TAB FUNCTION
local function CreateTab(name, icon)
	local Page = CreateInstance("ScrollingFrame", {
		Name = name,
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		BorderSizePixel = 0,
		ScrollBarThickness = 3,
		ScrollBarImageColor3 = C.AccentDim,
		CanvasSize = UDim2.new(0, 0, 0, 0),
		AutomaticCanvasSize = Enum.AutomaticSize.Y,
		Visible = false,
	}, ContentArea)

	CreateInstance("UIPadding", {
		PaddingTop = UDim.new(0, 16),
		PaddingLeft = UDim.new(0, 16),
		PaddingRight = UDim.new(0, 16),
		PaddingBottom = UDim.new(0, 16),
	}, Page)

	local PageList = CreateInstance("UIListLayout", {
		FillDirection = Enum.FillDirection.Vertical,
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 6),
	}, Page)

	-- SIDEBAR TAB BUTTON
	local TabBtn = CreateInstance("TextButton", {
		Name = name .. "Tab",
		Size = UDim2.new(0, 44, 0, 44),
		BackgroundColor3 = C.Sidebar,
		BorderSizePixel = 0,
		Text = icon,
		TextColor3 = C.TextMuted,
		Font = Enum.Font.GothamBold,
		TextSize = 18,
		AutoButtonColor = false,
	}, Sidebar)
	CreateInstance("UICorner", { CornerRadius = UDim.new(0, 10) }, TabBtn)

	-- Active Left Border indicator
	local ActiveBar = CreateInstance("Frame", {
		Size = UDim2.new(0, 3, 0, 24),
		Position = UDim2.new(0, -1, 0.5, -12),
		BackgroundColor3 = C.Accent,
		BorderSizePixel = 0,
		Visible = false,
	}, TabBtn)
	CreateInstance("UICorner", { CornerRadius = UDim.new(0, 2) }, ActiveBar)

	TabBtn.MouseEnter:Connect(function()
		if ActiveTab ~= name then
			Tween(TabBtn, { BackgroundColor3 = Color3.fromRGB(20, 20, 35) }, 0.15)
			Tween(TabBtn, { TextColor3 = C.TextDim }, 0.15)
		end
	end)
	TabBtn.MouseLeave:Connect(function()
		if ActiveTab ~= name then
			Tween(TabBtn, { BackgroundColor3 = C.Sidebar }, 0.15)
			Tween(TabBtn, { TextColor3 = C.TextMuted }, 0.15)
		end
	end)
	TabBtn.MouseButton1Click:Connect(function()
		-- Deactivate all
		for _, t in pairs(TabButtons) do
			Tween(t.btn, { BackgroundColor3 = C.Sidebar, TextColor3 = C.TextMuted }, 0.18)
			t.bar.Visible = false
			t.page.Visible = false
		end
		-- Activate selected
		ActiveTab = name
		Tween(TabBtn, { BackgroundColor3 = Color3.fromRGB(25, 25, 50), TextColor3 = C.Accent }, 0.18)
		ActiveBar.Visible = true
		Page.Visible = true
	end)

	Pages[name] = Page
	table.insert(TabButtons, { btn = TabBtn, bar = ActiveBar, page = Page, name = name })
	return Page, PageList
end

