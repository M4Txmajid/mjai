-- // APPLY THEME FUNCTION
local function ApplyTheme(themeName)
	local t = Themes[themeName]
	if not t then return end
	Tween(Window, { BackgroundColor3 = t.BG }, 0.4)
	Tween(Sidebar, { BackgroundColor3 = t.Sidebar }, 0.4)
	Tween(TopBar, { BackgroundColor3 = t.TopBar }, 0.4)
	-- Update rows in all pages
	for _, page in pairs(Pages) do
		for _, child in ipairs(page:GetDescendants()) do
			if child:IsA("Frame") and child.Name == "Row" then
				Tween(child, { BackgroundColor3 = t.Row }, 0.4)
			end
		end
	end
	-- Update C table for future rows
	C.BG = t.BG
	C.Sidebar = t.Sidebar
	C.Row = t.Row
end

-- // APPLY ACCENT FUNCTION
local function ApplyAccent(accentName)
	local color = Accents[accentName]
	if not color then return end
	C.Accent = color
	-- Update all toggle knobs that are ON
	for _, page in pairs(Pages) do
		for _, child in ipairs(page:GetDescendants()) do
			if child:IsA("Frame") and child.BackgroundColor3 == C.Accent then
				Tween(child, { BackgroundColor3 = color }, 0.3)
			end
		end
	end
	-- Update active tab bar and button color
	for _, t in pairs(TabButtons) do
		if t.name == ActiveTab then
			Tween(t.btn, { TextColor3 = color }, 0.3)
			Tween(t.bar, { BackgroundColor3 = color }, 0.3)
		end
	end
	-- Update slider fills
	for _, page in pairs(Pages) do
		for _, child in ipairs(page:GetDescendants()) do
			if child:IsA("Frame") and child.Name == "SliderFill" then
				Tween(child, { BackgroundColor3 = color }, 0.3)
			end
		end
	end
	-- Update UIStroke on slider thumbs
	for _, page in pairs(Pages) do
		for _, child in ipairs(page:GetDescendants()) do
			if child:IsA("UIStroke") and child.Color == C.Accent then
				Tween(child, { Color = color }, 0.3)
			end
		end
	end
	C.Accent = color
	C.AccentDim = Color3.fromRGB(
		math.floor(color.R * 200),
		math.floor(color.G * 200),
		math.floor(color.B * 200)
	)
end

