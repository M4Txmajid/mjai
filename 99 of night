	if not stroke then return end
	while FloatCircle.Visible do
		Tween(stroke, { Thickness = 4 }, 0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
		task.wait(0.85)
		Tween(stroke, { Thickness = 2 }, 0.8, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
		task.wait(0.85)
	end
end

