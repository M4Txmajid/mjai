-- LocalScript inside StarterPlayerScripts or StarterCharacterScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

local flying = false
local flySpeed = 50
local bodyVelocity = nil
local bodyGyro = nil

-- Mobile GUI
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "FlyGui"
screenGui.ResetOnSpawn = false
screenGui.Parent = player:WaitForChild("PlayerGui")

-- Fly toggle button
local flyBtn = Instance.new("TextButton")
flyBtn.Size = UDim2.new(0, 80, 0, 80)
flyBtn.Position = UDim2.new(1, -100, 1, -180)
flyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
flyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
flyBtn.Text = "FLY"
flyBtn.TextSize = 18
flyBtn.Font = Enum.Font.GothamBold
flyBtn.BorderSizePixel = 0
flyBtn.Parent = screenGui

local corner = Instance.new("UICorner")
corner.CornerRadius = UDim.new(1, 0)
corner.Parent = flyBtn

-- Up button
local upBtn = Instance.new("TextButton")
upBtn.Size = UDim2.new(0, 60, 0, 60)
upBtn.Position = UDim2.new(1, -170, 1, -190)
upBtn.BackgroundColor3 = Color3.fromRGB(50, 100, 255)
upBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
upBtn.Text = "▲"
upBtn.TextSize = 22
upBtn.Font = Enum.Font.GothamBold
upBtn.BorderSizePixel = 0
upBtn.Visible = false
upBtn.Parent = screenGui

local upCorner = Instance.new("UICorner")
upCorner.CornerRadius = UDim.new(1, 0)
upCorner.Parent = upBtn

-- Down button
local downBtn = Instance.new("TextButton")
downBtn.Size = UDim2.new(0, 60, 0, 60)
downBtn.Position = UDim2.new(1, -170, 1, -120)
downBtn.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
downBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
downBtn.Text = "▼"
downBtn.TextSize = 22
downBtn.Font = Enum.Font.GothamBold
downBtn.BorderSizePixel = 0
downBtn.Visible = false
downBtn.Parent = screenGui

local downCorner = Instance.new("UICorner")
downCorner.CornerRadius = UDim.new(1, 0)
downCorner.Parent = downBtn

local goingUp = false
local goingDown = false

-- Up/Down button listeners
upBtn.TouchStarted:Connect(function() goingUp = true end)
upBtn.TouchEnded:Connect(function() goingUp = false end)
downBtn.TouchStarted:Connect(function() goingDown = true end)
downBtn.TouchEnded:Connect(function() goingDown = false end)

local function startFly()
    flying = true
    flyBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 100)
    flyBtn.Text = "LAND"
    upBtn.Visible = true
    downBtn.Visible = true

    humanoid.PlatformStand = true

    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.Velocity = Vector3.zero
    bodyVelocity.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bodyVelocity.Parent = rootPart

    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    bodyGyro.D = 100
    bodyGyro.Parent = rootPart
end

local function stopFly()
    flying = false
    flyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    flyBtn.Text = "FLY"
    upBtn.Visible = false
    downBtn.Visible = false
    goingUp = false
    goingDown = false

    humanoid.PlatformStand = false

    if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
    if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
end

flyBtn.MouseButton1Click:Connect(function()
    if flying then
        stopFly()
    else
        startFly()
    end
end)

-- Main fly loop
RunService.Heartbeat:Connect(function()
    if not flying then return end
    if not rootPart or not bodyVelocity or not bodyGyro then return end

    local camera = workspace.CurrentCamera
    local moveDir = Vector3.zero

    -- Get movement from thumbstick (mobile)
    local thumbstick = UserInputService:GetNavigatorState()
    local moveVector = humanoid.MoveDirection

    if moveVector.Magnitude > 0.1 then
        local camCFrame = camera.CFrame
        local flatForward = Vector3.new(camCFrame.LookVector.X, 0, camCFrame.LookVector.Z).Unit
        local flatRight = Vector3.new(camCFrame.RightVector.X, 0, camCFrame.RightVector.Z).Unit
        moveDir = (flatForward * moveVector.Z * -1 + flatRight * moveVector.X)
    end

    local verticalDir = Vector3.zero
    if goingUp then
        verticalDir = Vector3.new(0, 1, 0)
    elseif goingDown then
        verticalDir = Vector3.new(0, -1, 0)
    end

    local finalVelocity = (moveDir + verticalDir)
    if finalVelocity.Magnitude > 1 then
        finalVelocity = finalVelocity.Unit
    end

    bodyVelocity.Velocity = finalVelocity * flySpeed

    -- Rotate to face movement direction
    if moveDir.Magnitude > 0.1 then
        bodyGyro.CFrame = CFrame.lookAt(Vector3.zero, moveDir)
    end
end)

-- Clean up on character respawn
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoid = newChar:WaitForChild("Humanoid")
    rootPart = newChar:WaitForChild("HumanoidRootPart")
    flying = false
    bodyVelocity = nil
    bodyGyro = nil
    flyBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    flyBtn.Text = "FLY"
    upBtn.Visible = false
    downBtn.Visible = false
end)
