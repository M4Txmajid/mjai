local CircleData = nil

local function createSmoothGlowCircle(radius)
	local segments = 64
	local centerPart = Instance.new("Part")
	centerPart.Name = "CircleCenter"
	centerPart.Anchored = true
	centerPart.CanCollide = false
	centerPart.CanQuery = false
	centerPart.CanTouch = false
	centerPart.Transparency = 1
	centerPart.Size = Vector3.new(1, 1, 1)
	centerPart.Parent = CircleFolder
	local attachments = {}
	local beams = {}
	for i = 1, segments do
		local angle = (i / segments) * math.pi * 2
		local x = math.cos(angle) * radius
		local z = math.sin(angle) * radius
		local attachment = Instance.new("Attachment")
		attachment.Name = "CirclePoint_" .. i
		attachment.Position = Vector3.new(x, 0, z)
		attachment.Parent = centerPart
		table.insert(attachments, attachment)
	end
	for i = 1, segments do
		local nextI = (i % segments) + 1
		local outerBeam = Instance.new("Beam")
		outerBeam.Attachment0 = attachments[i]
		outerBeam.Attachment1 = attachments[nextI]
		outerBeam.Color = ColorSequence.new(Color3.fromRGB(150, 220, 255))
		outerBeam.Transparency = NumberSequence.new(0.7)
		outerBeam.LightEmission = 1
		outerBeam.LightInfluence = 0
		outerBeam.Width0 = 2.5
		outerBeam.Width1 = 2.5
		outerBeam.FaceCamera = true
		outerBeam.Segments = 1
		outerBeam.Parent = centerPart
		table.insert(beams, outerBeam)
		local midBeam = Instance.new("Beam")
		midBeam.Attachment0 = attachments[i]
		midBeam.Attachment1 = attachments[nextI]
		midBeam.Color = ColorSequence.new(Color3.fromRGB(200, 240, 255))
		midBeam.Transparency = NumberSequence.new(0.4)
		midBeam.LightEmission = 1
		midBeam.LightInfluence = 0
		midBeam.Width0 = 1.0
		midBeam.Width1 = 1.0
		midBeam.FaceCamera = true
		midBeam.Segments = 1
		midBeam.Parent = centerPart
		table.insert(beams, midBeam)
		local coreBeam = Instance.new("Beam")
		coreBeam.Attachment0 = attachments[i]
		coreBeam.Attachment1 = attachments[nextI]
		coreBeam.Color = ColorSequence.new(Color3.fromRGB(255, 255, 255))
		coreBeam.Transparency = NumberSequence.new(0)
		coreBeam.LightEmission = 1
		coreBeam.LightInfluence = 0
		coreBeam.Width0 = 0.25
		coreBeam.Width1 = 0.25
		coreBeam.FaceCamera = true
		coreBeam.Segments = 1
		coreBeam.Parent = centerPart
		table.insert(beams, coreBeam)
	end
	return { centerPart = centerPart, attachments = attachments, beams = beams, radius = radius }
end

local pulseTime = 0

function initCircles()
	CircleFolder:ClearAllChildren()
	CircleData = createSmoothGlowCircle(CONFIG.CUT_RANGE)
end

local function updateCirclePosition(pos, dt)
	if not CircleData or not CircleData.centerPart then return end
	pulseTime = pulseTime + dt
	CircleData.centerPart.CFrame = CFrame.new(pos.X, pos.Y + 0.2, pos.Z)
	local pulse = 0.9 + math.sin(pulseTime * 3) * 0.1
	local glowPulse = 0.6 + math.sin(pulseTime * 2) * 0.15
	for _, beam in pairs(CircleData.beams) do
		if beam.Name:find("OuterGlow") then
			beam.Transparency = NumberSequence.new(glowPulse + 0.1)
			beam.Width0 = 2.5 * pulse
			beam.Width1 = 2.5 * pulse
		elseif beam.Name:find("MidGlow") then
			beam.Transparency = NumberSequence.new(glowPulse - 0.2)
			beam.Width0 = 1.0 * pulse
			beam.Width1 = 1.0 * pulse
		elseif beam.Name:find("Core") then
			beam.Width0 = 0.25 * pulse
			beam.Width1 = 0.25 * pulse
		end
	end
end

function destroyCircles()
	CircleFolder:ClearAllChildren()
	CircleData = nil
	pulseTime = 0
end

local HighlightFolder = Instance.new("Folder")
HighlightFolder.Name = "TreeHL"
HighlightFolder.Parent = workspace.CurrentCamera

function highlightTree(tree, state)
	local hl = nil
	for _, h in pairs(HighlightFolder:GetChildren()) do
		if h.Adornee == tree then hl = h break end
	end
	if not hl then
		hl = Instance.new("Highlight")
		hl.Name = tree.Name
		hl.Adornee = tree
		hl.FillTransparency = 0.7
		hl.OutlineTransparency = 0
		hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
		hl.Parent = HighlightFolder
	end
	if state == "cutting" then
		hl.FillColor = Color3.fromRGB(255, 100, 0)
		hl.OutlineColor = Color3.fromRGB(255, 50, 0)
	elseif state == "inrange" then
		hl.FillColor = Color3.fromRGB(0, 255, 0)
		hl.OutlineColor = Color3.fromRGB(0, 200, 0)
	else
		hl.FillColor = Color3.fromRGB(255, 255, 255)
		hl.OutlineColor = Color3.fromRGB(150, 150, 150)
	end
end

function removeHighlight(tree)
	for _, h in pairs(HighlightFolder:GetChildren()) do
		if h.Adornee == tree then h:Destroy() break end
	end
end

function clearHighlights()
	HighlightFolder:ClearAllChildren()
end

local currentlyActive = false

Player.CharacterAdded:Connect(function(char)
	Character = char
	HRP = char:WaitForChild("HumanoidRootPart")
end)

local function getTool()
	local inv = Player:FindFirstChild("Inventory")
	if inv then return inv:FindFirstChild(CONFIG.TOOL_NAME) end
	return nil
end

local function getTreePos(tree)
	local pos
	pcall(function()
		if tree.PrimaryPart then pos = tree.PrimaryPart.Position
		elseif tree:IsA("BasePart") then pos = tree.Position
		else pos = tree:GetPivot().Position end
	end)
	return pos
end

local function getDistance(tree)
	if not HRP or not HRP.Parent then return math.huge end
	local pos = getTreePos(tree)
	if not pos then return math.huge end
	return (HRP.Position - pos).Magnitude
end

local function isResource(obj)
	return obj:GetAttribute("Interaction") == "Resource" or obj:GetAttribute("Resource") ~= nil
end

local function isTreeAlive(tree)
	if not tree or not tree.Parent then return false end
	local hp = tree:GetAttribute("Health")
	if not hp or hp <= 0 then return false end
	return true
end

local function hitTreeOnceAsync(tree, tool)
	if not tree or not tree.Parent then return end
	if not isTreeAlive(tree) then return end
	if not HRP or not HRP.Parent then return end
	if getDistance(tree) > CONFIG.CUT_RANGE then return end
	local validStr = generateValidationString()
	pcall(function()
		ToolDamageEvent:InvokeServer(tree, tool, validStr, HRP.CFrame)
	end)
end

local function hitTreesSimultaneously(treeList, tool)
	local hitTrees = {}
	for _, tree in ipairs(treeList) do
		if tree and tree.Parent and isTreeAlive(tree) then
			highlightTree(tree, "cutting")
			table.insert(hitTrees, tree)
			task.spawn(function() hitTreeOnceAsync(tree, tool) end)
		end
	end
	return hitTrees
end

local function getTreesInRange()
	local trees = {}
	local foliage = workspace:FindFirstChild("Map")
	foliage = foliage and foliage:FindFirstChild("Foliage")
	if not foliage then return trees end
	for _, tree in pairs(foliage:GetChildren()) do
		if isResource(tree) and tree.Parent and isTreeAlive(tree) then
			if getDistance(tree) <= CONFIG.CUT_RANGE then
				table.insert(trees, tree)
			end
		end
	end
	return trees
end

RunService.RenderStepped:Connect(function(dt)
	if not CONFIG.ENABLED then return end
	if not HRP or not HRP.Parent then return end
	updateCirclePosition(HRP.Position, dt)
	local foliage = workspace:FindFirstChild("Map")
	foliage = foliage and foliage:FindFirstChild("Foliage")
	if foliage then
		for _, tree in pairs(foliage:GetChildren()) do
			if isTreeAlive(tree) and getDistance(tree) <= CONFIG.CUT_RANGE and not currentlyActive then
				highlightTree(tree, "inrange")
			end
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(0.02)
		if not CONFIG.ENABLED then currentlyActive = false continue end
		local tool = getTool()
		if not tool then task.wait(1) continue end
		if not HRP or not HRP.Parent then task.wait(0.5) continue end
		local trees = getTreesInRange()
		if #trees == 0 then currentlyActive = false task.wait(0.2) continue end
		currentlyActive = true
		local batchSize = CONFIG.SIMULTANEOUS_HITS
		local index = 1
		while index <= #trees and CONFIG.ENABLED do
			local batch = {}
			for i = 0, batchSize - 1 do
				local treeIndex = index + i
				if treeIndex <= #trees then
					local tree = trees[treeIndex]
					if tree and tree.Parent and isTreeAlive(tree) then
						table.insert(batch, tree)
					end
				end
			end
			if #batch > 0 then
				local hitTrees = hitTreesSimultaneously(batch, tool)
				task.wait(CONFIG.HIT_COOLDOWN + 0.05)
				for _, tree in ipairs(hitTrees) do
					if not isTreeAlive(tree) then removeHighlight(tree) end
				end
			end
			index = index + batchSize
		end
	end
end)

-- // UTILITIES
local function Tween(obj, props, duration, style, direction)
	local info = TweenInfo.new(duration or 0.2, style or Enum.EasingStyle.Quint, direction or Enum.EasingDirection.Out)
	local t = TweenService:Create(obj, info, props)
	t:Play()
	return t
end

local function CreateInstance(class, props, parent)
	local obj = Instance.new(class)
	for k, v in pairs(props) do
		obj[k] = v
	end
	if parent then obj.Parent = parent end
	return obj
end

