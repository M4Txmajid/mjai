-- TOGGLE ROW
local function AddToggle(parent, labelText, default, callback)
	local row, Label = MakeRow(parent, true)
	Label.Text = labelText

	local ToggleBG = CreateInstance("Frame", {
		Size = UDim2.new(0, 40, 0, 22),
		Position = UDim2.new(1, -40, 0.5, -11),
		BackgroundColor3 = default and C.Accent or C.ToggleOff,
		BorderSizePixel = 0,
	}, row)
	CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }, ToggleBG)

	if default then
		CreateInstance("UIStroke", { Color = C.Accent, Thickness = 0, ApplyStrokeMode = Enum.ApplyStrokeMode.Border }, ToggleBG)
	end

	local Knob = CreateInstance("Frame", {
		Size = UDim2.new(0, 16, 0, 16),
		Position = default and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8),
		BackgroundColor3 = C.White,
		BorderSizePixel = 0,
	}, ToggleBG)
	CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }, Knob)

	local state = default or false
	local ClickArea = CreateInstance("TextButton", {
		Size = UDim2.new(1, 0, 1, 0),
		BackgroundTransparency = 1,
		Text = "",
	}, row)

	ClickArea.MouseButton1Click:Connect(function()
		state = not state
		if state then
			Tween(ToggleBG, { BackgroundColor3 = C.Accent }, 0.2)
			Tween(Knob, { Position = UDim2.new(1, -19, 0.5, -8) }, 0.2, Enum.EasingStyle.Quint)
		else
			Tween(ToggleBG, { BackgroundColor3 = C.ToggleOff }, 0.2)
			Tween(Knob, { Position = UDim2.new(0, 3, 0.5, -8) }, 0.2, Enum.EasingStyle.Quint)
		end
		if callback then callback(state) end
	end)

	return row
end

-- SLIDER ROW
local function AddSlider(parent, labelText, min, max, default, suffix, callback)
	local row, Label = MakeRow(parent, false)
	row.Size = UDim2.new(1, 0, 0, 46)
	Label.Text = labelText
	Label.Size = UDim2.new(0.45, 0, 1, 0)

	local ValLabel = CreateInstance("TextLabel", {
		Size = UDim2.new(0, 50, 0, 20),
		Position = UDim2.new(0.45, 0, 0.5, -10),
		BackgroundTransparency = 1,
		Text = tostring(default) .. (suffix or ""),
		TextColor3 = C.TextDim,
		Font = Enum.Font.GothamBold,
		TextSize = 12,
		TextXAlignment = Enum.TextXAlignment.Right,
	}, row)

	local TrackBG = CreateInstance("Frame", {
		Size = UDim2.new(0.42, 0, 0, 4),
		Position = UDim2.new(0.57, 0, 0.5, -2),
		BackgroundColor3 = C.SliderBG,
		BorderSizePixel = 0,
	}, row)
	CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }, TrackBG)

	local pct = (default - min) / (max - min)

	local Fill = CreateInstance("Frame", {
		Size = UDim2.new(pct, 0, 1, 0),
		BackgroundColor3 = C.Accent,
		BorderSizePixel = 0,
	}, TrackBG)
	CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }, Fill)

	local Thumb = CreateInstance("Frame", {
		Size = UDim2.new(0, 13, 0, 13),
		Position = UDim2.new(pct, -6, 0.5, -6),
		BackgroundColor3 = C.White,
		BorderSizePixel = 0,
	}, TrackBG)
	CreateInstance("UICorner", { CornerRadius = UDim.new(1, 0) }, Thumb)
	CreateInstance("UIStroke", { Color = C.Accent, Thickness = 2 }, Thumb)

	local dragging = false
	local ClickTarget = CreateInstance("TextButton", {
		Size = UDim2.new(1, 0, 0, 20),
		Position = UDim2.new(0, 0, 0.5, -10),
		BackgroundTransparency = 1,
		Text = "",
	}, TrackBG)

	local function UpdateSlider(inputX)
		local trackPos = TrackBG.AbsolutePosition.X
		local trackSize = TrackBG.AbsoluteSize.X
		local rel = math.clamp((inputX - trackPos) / trackSize, 0, 1)
		local value = math.round(min + rel * (max - min))
		local newPct = (value - min) / (max - min)
		Tween(Fill, { Size = UDim2.new(newPct, 0, 1, 0) }, 0.05)
		Tween(Thumb, { Position = UDim2.new(newPct, -6, 0.5, -6) }, 0.05)
		ValLabel.Text = tostring(value) .. (suffix or "")
		if callback then callback(value) end
	end

	-- Mouse support
	ClickTarget.MouseButton1Down:Connect(function()
		dragging = true
		UpdateSlider(Mouse.X)
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement
			or input.UserInputType == Enum.UserInputType.Touch) then
			UpdateSlider(input.Position.X)
		end
	end)

	-- Touch support
	ClickTarget.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			UpdateSlider(input.Position.X)
		end
	end)
	ClickTarget.InputChanged:Connect(function(input)
		if dragging and input.UserInputType == Enum.UserInputType.Touch then
			UpdateSlider(input.Position.X)
		end
	end)
	ClickTarget.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
		end
	end)

	return row
end

-- DROPDOWN ROW
local function AddDropdown(parent, labelText, options, default, callback)
	local row, Label = MakeRow(parent, false)
	Label.Text = labelText

	local selected = default or options[1]

	local DropBtn = CreateInstance("TextButton", {
		Size = UDim2.new(0, 120, 0, 26),
		Position = UDim2.new(1, -120, 0.5, -13),
		BackgroundColor3 = Color3.fromRGB(22, 22, 38),
		BorderSizePixel = 0,
		Text = selected .. "  ▾",
		TextColor3 = C.TextPrim,
		Font = Enum.Font.Gotham,
		TextSize = 12,
		AutoButtonColor = false,
	}, row)
	CreateInstance("UICorner", { CornerRadius = UDim.new(0, 7) }, DropBtn)
	CreateInstance("UIStroke", { Color = Color3.fromRGB(45,45,70), Thickness = 1 }, DropBtn)

	local open = false
	local dropHeight = #options * 28 + 6

	-- Parent to ScreenGui so it renders on top of everything
	local DropFrame = CreateInstance("Frame", {
		Size = UDim2.new(0, 120, 0, dropHeight),
		Position = UDim2.new(0, 0, 0, 0), -- will be updated on open
		BackgroundColor3 = Color3.fromRGB(20, 20, 36),
		BorderSizePixel = 0,
		Visible = false,
		ZIndex = 100,
	}, ScreenGui)
	CreateInstance("UICorner", { CornerRadius = UDim.new(0, 8) }, DropFrame)
	CreateInstance("UIStroke", { Color = Color3.fromRGB(50,50,80), Thickness = 1 }, DropFrame)
	CreateInstance("UIPadding", { PaddingTop = UDim.new(0,3), PaddingBottom = UDim.new(0,3) }, DropFrame)

	local DropList = CreateInstance("UIListLayout", {
		SortOrder = Enum.SortOrder.LayoutOrder,
		Padding = UDim.new(0, 1),
	}, DropFrame)

	for _, opt in ipairs(options) do
		local OptBtn = CreateInstance("TextButton", {
			Size = UDim2.new(1, 0, 0, 27),
			BackgroundColor3 = Color3.fromRGB(20,20,36),
			BorderSizePixel = 0,
			Text = opt,
			TextColor3 = opt == selected and C.Accent or C.TextDim,
			Font = Enum.Font.Gotham,
			TextSize = 12,
			AutoButtonColor = false,
			ZIndex = 101,
		}, DropFrame)
		CreateInstance("UICorner", { CornerRadius = UDim.new(0, 6) }, OptBtn)

		OptBtn.MouseEnter:Connect(function() Tween(OptBtn, { BackgroundColor3 = Color3.fromRGB(28,28,50) }, 0.1) end)
		OptBtn.MouseLeave:Connect(function() Tween(OptBtn, { BackgroundColor3 = Color3.fromRGB(20,20,36) }, 0.1) end)
		OptBtn.MouseButton1Click:Connect(function()
			selected = opt
			DropBtn.Text = opt .. "  ▾"
			open = false
			DropFrame.Visible = false
			if callback then callback(opt) end
		end)
	end

	DropBtn.MouseButton1Click:Connect(function()
		open = not open
		if open then
			-- Calculate absolute screen position of the button
			local btnPos = DropBtn.AbsolutePosition
			local btnSize = DropBtn.AbsoluteSize
			DropFrame.Position = UDim2.new(0, btnPos.X, 0, btnPos.Y + btnSize.Y + 4)
		end
		DropFrame.Visible = open
	end)

	-- Close dropdown if clicked outside
	UserInputService.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and open then
			local mpos = UserInputService:GetMouseLocation()
			local fpos = DropFrame.AbsolutePosition
			local fsize = DropFrame.AbsoluteSize
			if mpos.X < fpos.X or mpos.X > fpos.X + fsize.X or mpos.Y < fpos.Y or mpos.Y > fpos.Y + fsize.Y then
				open = false
				DropFrame.Visible = false
			end
		end
	end)

	return row
end

