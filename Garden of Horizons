--// ===================== TWEEN ===================== --
local function smoothTween(targetCFrame, speed)
	if not rootPart or not rootPart.Parent then return false end
	if ST.respawning then return false end
	if not ST.running and not ST.autoTrialEnabled and not ST.returning then return false end
	local distance = (rootPart.Position - targetCFrame.Position).Magnitude
	if distance < 1 then rootPart.CFrame = targetCFrame; return true end
	local tweenTime = math.max(distance / speed, 0.05)
	if ST.bodyVel and ST.bodyVel.Parent then ST.bodyVel.MaxForce = Vector3.zero end
	rootPart.Velocity = Vector3.zero; rootPart.AssemblyLinearVelocity = Vector3.zero; rootPart.AssemblyAngularVelocity = Vector3.zero
	local guard = RunService.Heartbeat:Connect(function()
		if not rootPart or not rootPart.Parent then return end
		rootPart.Velocity = Vector3.zero; rootPart.AssemblyLinearVelocity = Vector3.zero; rootPart.AssemblyAngularVelocity = Vector3.zero
		pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end) end)
	ST.currentTween = TweenService:Create(rootPart, TweenInfo.new(tweenTime, Enum.EasingStyle.Linear), {CFrame = targetCFrame})
	ST.tweening = true; ST.currentTween:Play(); ST.currentTween.Completed:Wait(); ST.tweening = false; guard:Disconnect()
	rootPart.CFrame = targetCFrame; rootPart.Velocity = Vector3.zero; rootPart.AssemblyLinearVelocity = Vector3.zero; rootPart.AssemblyAngularVelocity = Vector3.zero
	if ST.bodyVel and ST.bodyVel.Parent then ST.bodyVel.Velocity = Vector3.zero; ST.bodyVel.MaxForce = Vector3.new(1e9,1e9,1e9) end; return true
end
local function stopTween()
	if ST.currentTween then ST.currentTween:Cancel(); ST.currentTween = nil; ST.tweening = false end
	if ST.bodyVel and ST.bodyVel.Parent then ST.bodyVel.Velocity = Vector3.zero; ST.bodyVel.MaxForce = Vector3.new(1e9,1e9,1e9) end
	if rootPart and rootPart.Parent then rootPart.Velocity = Vector3.zero; rootPart.AssemblyLinearVelocity = Vector3.zero; rootPart.AssemblyAngularVelocity = Vector3.zero end
end

