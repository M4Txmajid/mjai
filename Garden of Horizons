        page.Name = def.Name
        page.Size = UDim2.new(1, 0, 1, 0)
        page.BackgroundTransparency = 1
        page.BorderSizePixel = 0
        page.ScrollBarThickness = 3
        page.ScrollBarImageColor3 = def.Color
        page.ScrollBarImageTransparency = 0.5
        page.CanvasSize = UDim2.new(0, 0, 0, 0)
        page.AutomaticCanvasSize = Enum.AutomaticSize.Y
        page.Visible = false
        page.ZIndex = 3
        page.Parent = Content
        local pl = Instance.new("UIListLayout")
        pl.Padding = UDim.new(0, 7)
        pl.Parent = page
        Fn.Pad(page, 10, 14, 10, 10)
        UI.Pages[def.Name] = page
    end

    function Fn.SwitchTab(name)
        if UI.ActiveTab == name then return end
        UI.ActiveTab = name
        for pn, page in pairs(UI.Pages) do page.Visible = (pn == name) end
        for i, def in ipairs(TabDefs) do
            local btn     = UI.NavBtns[def.Name]
            local pill    = UI.NavBtns[def.Name .. "_pill"]
            local lbl     = UI.NavBtns[def.Name .. "_lbl"]
            local isActive = (def.Name == name)
            if btn  then Fn.Tween(btn,  { BackgroundColor3 = isActive and C.Elevated or Color3.fromRGB(10, 10, 16) }, 0.15) end
            if pill then
                pill.Visible = isActive
                if isActive then Fn.Tween(pill, { BackgroundColor3 = def.Color }, 0.15) end
            end
            if lbl  then Fn.Tween(lbl,  { TextColor3 = isActive and def.Color or C.TextMuted }, 0.15) end
        end
    end

    for i, def in ipairs(TabDefs) do
        local bH = State.IsMobile and 52 or 48

        local btn = Instance.new("TextButton")
        btn.Name = def.Name
        btn.Size = UDim2.new(1, -8, 0, bH)
        btn.BackgroundColor3 = (i == 1) and C.Elevated or Color3.fromRGB(10, 10, 16)
        btn.BorderSizePixel = 0
        btn.Text = ""
        btn.AutoButtonColor = false
        btn.LayoutOrder = i
        btn.ZIndex = 9
        btn.Parent = NavScroll
        Fn.Corner(btn, 8)

        -- Active left pill indicator
        local pill = Instance.new("Frame")
        pill.Size = UDim2.new(0, 3, 0.55, 0)
        pill.Position = UDim2.new(0, 0, 0.225, 0)
        pill.BackgroundColor3 = def.Color
        pill.BorderSizePixel = 0
        pill.Visible = (i == 1)
        pill.ZIndex = 11
        pill.Parent = btn
        Fn.Corner(pill, 2)

        -- Tab name label
        local lbl = Instance.new("TextLabel")
        lbl.Size = UDim2.new(1, -6, 1, 0)
        lbl.Position = UDim2.new(0, 6, 0, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = def.Name
        lbl.TextSize = Fn.FS(State.IsMobile and 10 or 9)
        lbl.Font = Enum.Font.GothamBold
        lbl.TextColor3 = (i == 1) and def.Color or C.TextMuted
        lbl.ZIndex = 9
        lbl.Parent = btn
        lbl.TextXAlignment = Enum.TextXAlignment.Center
        lbl.TextYAlignment = Enum.TextYAlignment.Center

        btn.MouseButton1Click:Connect(function() Fn.SwitchTab(def.Name) end)
        Fn.Ripple(btn)

        if not State.IsMobile then
            btn.MouseEnter:Connect(function()
                if UI.ActiveTab ~= def.Name then
                    Fn.Tween(btn, { BackgroundColor3 = C.Hover }, 0.1)
                    Fn.Tween(lbl, { TextColor3 = C.TextSub }, 0.1)
                end
            end)
            btn.MouseLeave:Connect(function()
                if UI.ActiveTab ~= def.Name then
                    Fn.Tween(btn, { BackgroundColor3 = Color3.fromRGB(10, 10, 16) }, 0.1)
                    Fn.Tween(lbl, { TextColor3 = C.TextMuted }, 0.1)
                end
            end)
        end

        UI.NavBtns[def.Name]            = btn
        UI.NavBtns[def.Name .. "_pill"] = pill
        UI.NavBtns[def.Name .. "_lbl"]  = lbl
    end
end



    
