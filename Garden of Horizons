local function resetRarityTracker() ST.previousTrialRarity=nil; ST.currentTrialRarity=nil; ST.currentTrialFolder=nil; ST.lastScanResult=nil; ST.lastScanFolder=nil; ST.rarityChangeCount=0; ST.trackerScanCount=0 end

local function updateTrackerLabel()
	if not UI.TrialTrackerLabel then return end
	if ST.currentTrialRarity and ST.currentTrialFolder then
		local ci = ""; if ST.rarityChangeCount > 0 then ci = string.format(" |S:%d", ST.rarityChangeCount); if ST.previousTrialRarity then ci = ci..string.format("(%s)", ST.previousTrialRarity) end end
		UI.TrialTrackerLabel.Text = string.format("★%s★%s%s", ST.currentTrialFolder, ci, ST.trackerScanCount > 0 and string.format(" [#%d]", ST.trackerScanCount) or "")
		UI.TrialTrackerLabel.TextColor3 = Color3.fromRGB(0,255,200)
	else UI.TrialTrackerLabel.Text = "Tracker: Waiting..."; UI.TrialTrackerLabel.TextColor3 = Color3.fromRGB(255,150,255) end
end
local function updateTrialTimerDisplay()
	if not UI.TrialDebugLabel then return end
	local a,t = isTrialTimerActive(); if a then UI.TrialDebugLabel.Text = "Timer: "..t
	else local o,c = isTrialOnCooldown(); if o then UI.TrialDebugLabel.Text = "CD: "..c else UI.TrialDebugLabel.Text = "Timer: Ready" end end
end

local function trackerRescanAtTower()
	task.wait(0.3)
	local nr, nc = readInfoFrameDirect()
	if not nr then
		task.wait(0.3); nr, nc = readInfoFrameDirect()
	end
	if not nr then
		local _, _, _, di; nr,nc,_,di = scanWithRetry(4,0.3)
		if not nr then task.wait(0.4); nr,nc,_,di = scanWithRetry(3,0.4) end
		if not nr then return nil,nil,"completed","no_rarity" end
	end
	local nf = matchRarityToFolder(nr); if not nf then return nr,nc,"no_folder","" end
	ST.lastScanResult=nr; ST.lastScanFolder=nf
	if ST.currentTrialRarity and nr ~= ST.currentTrialRarity then
		ST.previousTrialRarity=ST.currentTrialRarity; ST.currentTrialRarity=nr; ST.currentTrialFolder=nf
		ST.rarityChangeCount=ST.rarityChangeCount+1; autoSelectTrialRarity(nf); return nr,nc,"changed",""
	end
	ST.currentTrialRarity=nr; ST.currentTrialFolder=nf; return nr,nc,"same",""
end

local function startContinuousTracker()
	if ST.continuousTrackerRunning then return end
	ST.continuousTrackerRunning = true
	ST.trackerScanCount = 0
	task.spawn(function()
		while ST.autoTrialEnabled and ST.continuousTrackerRunning do
			if ST.trialInProgress and ST.trialCollecting then
				ST.trackerScanCount = ST.trackerScanCount + 1
				local nr, nc = readInfoFrameDirect()
				if nr then
					local nf = matchRarityToFolder(nr)
					if nf then
						if ST.currentTrialRarity and nr ~= ST.currentTrialRarity then
							ST.previousTrialRarity = ST.currentTrialRarity
							ST.currentTrialRarity = nr
							ST.currentTrialFolder = nf
							ST.rarityChangeCount = ST.rarityChangeCount + 1
							ST.trialRequired = nc or 1
							autoSelectTrialRarity(nf)
							if UI.TrialStatusLabel then
								UI.TrialStatusLabel.Text = string.format("Changed! Need %d %s", nc or 1, nf)
								UI.TrialStatusLabel.TextColor3 = Color3.fromRGB(255, 200, 0)
							end
						else
							ST.currentTrialRarity = nr
							ST.currentTrialFolder = nf
							ST.trialRequired = nc or ST.trialRequired
						end
						ST.lastScanResult = nr
						ST.lastScanFolder = nf
					end
				end
				updateTrackerLabel()
				updateTrialTimerDisplay()
			end
			checkMapChange()
			task.wait(0.5)
		end
		ST.continuousTrackerRunning = false
	end)
end
local function stopContinuousTracker() ST.continuousTrackerRunning = false end

