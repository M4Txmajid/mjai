		if string.find(child.Name, "SharedInstances") or string.find(child.Name, "_Shared") then
			local nd = {}; for _, d in pairs(ST.floorOriginalData) do if d.Part and d.Part.Parent then table.insert(nd, d) end end; ST.floorOriginalData = nd
