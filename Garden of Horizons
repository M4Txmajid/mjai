	ST.savedWalkSpeed=humanoid.WalkSpeed; ST.savedJumpPower=humanoid.JumpPower; humanoid.WalkSpeed=0; humanoid.JumpPower=0
	pcall(function() humanoid.JumpHeight=0 end)
	for _,s in ipairs({Enum.HumanoidStateType.Swimming,Enum.HumanoidStateType.Freefall,Enum.HumanoidStateType.FallingDown,Enum.HumanoidStateType.Ragdoll,Enum.HumanoidStateType.GettingUp,Enum.HumanoidStateType.Jumping,Enum.HumanoidStateType.Landed,Enum.HumanoidStateType.Climbing}) do pcall(function() humanoid:SetStateEnabled(s,false) end) end
	pcall(function() humanoid:ChangeState(Enum.HumanoidStateType.Physics) end)
	for _,o in pairs(rootPart:GetChildren()) do if o.Name=="_BrainLock" then o:Destroy() end end
	ST.bodyVel=Instance.new("BodyVelocity"); ST.bodyVel.Name="_BrainLock"; ST.bodyVel.Velocity=Vector3.zero; ST.bodyVel.MaxForce=Vector3.new(1e9,1e9,1e9); ST.bodyVel.P=1e9; ST.bodyVel.Parent=rootPart
