--// ===================== FLOOR SCANNER ===================== --
local function findCurrentFloorsFolder()
	for _, child in pairs(workspace:GetChildren()) do
		if string.find(child.Name, "SharedInstances") or string.find(child.Name, "_Shared") then
			local floors = child:FindFirstChild("Floors")
			if floors then return floors, child.Name end
			for _, desc in pairs(child:GetDescendants()) do if desc.Name == "Floors" then return desc, child.Name end end
		end
	end
	for _, child in pairs(workspace:GetChildren()) do
		if child.Name == "Floors" then return child, "workspace" end
		local floors = child:FindFirstChild("Floors"); if floors then return floors, child.Name end
	end
	for _, desc in pairs(workspace:GetDescendants()) do
		if desc.Name == "Floors" and #desc:GetChildren() > 0 then
			local has = false; for _, fc in pairs(desc:GetDescendants()) do if fc:IsA("BasePart") then has = true; break end end
			if has then return desc, desc.Parent and desc.Parent.Name or "unknown" end
		end
	end; return nil, "None"
end
local function getAllFloorParts(f)
	local parts = {}; if not f or not f.Parent then return parts end
	for _, d in pairs(f:GetDescendants()) do if d:IsA("BasePart") then table.insert(parts, d) end end; return parts
end
local function clearFloors()
	if not ST.floorClearEnabled or ST.floorsCleared then return end
	local f, m = findCurrentFloorsFolder(); if not f then ST.currentMapName = "No floors"; return end
	ST.currentMapName = m; ST.floorsCleared = true; ST.floorOriginalData = {}
	for _, p in pairs(getAllFloorParts(f)) do
		table.insert(ST.floorOriginalData, {Part=p, Transparency=p.Transparency, CanCollide=p.CanCollide})
		p.Transparency = 1; p.CanCollide = false
	end
end
local function restoreFloors()
	if not ST.floorsCleared then return end
	for _, d in pairs(ST.floorOriginalData) do if d.Part and d.Part.Parent then d.Part.Transparency = d.Transparency; d.Part.CanCollide = d.CanCollide end end
	ST.floorOriginalData = {}; ST.floorsCleared = false
end
local function updateFloorLabel()
	if not UI.FloorLabel then return end
	if ST.floorsCleared then
		UI.FloorLabel.Text = string.format("Floors: CLEARED [%s] (%d)", ST.currentMapName:gsub("_SharedInstances",""):gsub("SharedInstances",""), #ST.floorOriginalData)
		UI.FloorLabel.TextColor3 = Color3.fromRGB(255,100,100)
	else
		local f, m = findCurrentFloorsFolder()
		if f then UI.FloorLabel.Text = string.format("Floors: Ready [%s] (%d)", m:gsub("_SharedInstances",""):gsub("SharedInstances",""), #getAllFloorParts(f)); UI.FloorLabel.TextColor3 = Color3.fromRGB(100,255,100)
		else UI.FloorLabel.Text = "Floors: No map"; UI.FloorLabel.TextColor3 = Color3.fromRGB(255,180,80) end
	end
end
local function checkMapChange()
	if ST.floorClearEnabled and ST.floorsCleared then
		local f, m = findCurrentFloorsFolder()
		if f and m ~= ST.currentMapName then restoreFloors(); task.wait(0.3); clearFloors(); updateFloorLabel() end
	end
end
local function startMapWatcher()
	if ST.mapWatcherConnection then return end
	ST.mapWatcherConnection = workspace.ChildAdded:Connect(function(child)
		if string.find(child.Name, "SharedInstances") or string.find(child.Name, "_Shared") then
			task.wait(2); local floors = child:FindFirstChild("Floors")
			if not floors then for _, d in pairs(child:GetDescendants()) do if d.Name == "Floors" then floors = d; break end end end
			if floors then if ST.floorsCleared then restoreFloors() end; ST.currentMapName = child.Name
				if ST.running or ST.autoTrialRunning then task.wait(0.5); clearFloors() end; updateFloorLabel() end
		end end)
