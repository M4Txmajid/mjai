        DwnBtn.TextSize = 32
        DwnBtn.Font = Enum.Font.GothamBold
        DwnBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
        DwnBtn.BorderSizePixel = 0
        DwnBtn.ZIndex = 51
        DwnBtn.Parent = FlyMobileFrame
        Fn.Corner(DwnBtn, 15)

        -- Joystick logic
        local maxRadius = 40

        local function updateJoy(pos)
            local center  = JoyBase.AbsolutePosition + JoyBase.AbsoluteSize / 2
            local offset   = Vector2.new(pos.X - center.X, pos.Y - center.Y)
            local dist     = math.min(offset.Magnitude, maxRadius)
            local dir      = offset.Magnitude > 0 and offset.Unit or Vector2.new(0, 0)
            local clamped  = dir * dist
            JoyInner.Position  = UDim2.new(0.5, clamped.X - 30, 0.5, clamped.Y - 30)
            fly_joystickInput  = Vector2.new(clamped.X / maxRadius, clamped.Y / maxRadius)
        end

        local function resetJoy()
            fly_joystickActive = false
            fly_joystickInput  = Vector2.new(0, 0)
            TweenService:Create(JoyInner, TweenInfo.new(0.2, Enum.EasingStyle.Back), {
                Position = UDim2.new(0.5, -30, 0.5, -30)
            }):Play()
        end

        JoyBase.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then
                fly_joystickActive = true
                updateJoy(i.Position)
            end
        end)
        JoyBase.InputChanged:Connect(function(i)
            if fly_joystickActive and i.UserInputType == Enum.UserInputType.Touch then
                updateJoy(i.Position)
            end
        end)
        JoyBase.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then resetJoy() end
        end)
        UserInputService.TouchMoved:Connect(function(t)
            if fly_joystickActive then updateJoy(t.Position) end
        end)
        UserInputService.TouchEnded:Connect(function()
            if fly_joystickActive then resetJoy() end
        end)

        -- Up / Down buttons
        UpBtn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then
                fly_upPressed = true
                fly_verticalInput = 1
            end
        end)
        UpBtn.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then
                fly_upPressed = false
                if not fly_downPressed then fly_verticalInput = 0 end
            end
        end)
        DwnBtn.InputBegan:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then
                fly_downPressed = true
                fly_verticalInput = -1
            end
        end)
        DwnBtn.InputEnded:Connect(function(i)
            if i.UserInputType == Enum.UserInputType.Touch then
                fly_downPressed = false
                if not fly_upPressed then fly_verticalInput = 0 end
            end
        end)

        -- Also hide mobile controls on character remove
        LP.CharacterRemoving:Connect(function()
            fly_joystickInput  = Vector2.new(0, 0)
            fly_verticalInput  = 0
            fly_upPressed      = false
            fly_downPressed    = false
        end)
    end
    

    Fn.Sep(P, "HOW IT WORKS")
