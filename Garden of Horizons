do
    function Fn.FindMyBase()
        if State.MyBase and State.MyBase.Parent then return State.MyBase end
        local bf=workspace:FindFirstChild("Bases"); if not bf then return nil end
        local char=LP.Character; if not char then return nil end
        local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return nil end
        local best,bd=nil,math.huge
        for _,base in ipairs(bf:GetChildren()) do
            for _,p in ipairs(base:GetDescendants()) do
                if p:IsA("BasePart") then
                    local d=(hrp.Position-p.Position).Magnitude
                    if d<bd then bd=d best=base end
                end
            end
        end
        State.MyBase=best; return best
    end

    local function CollectSlots()
        if not State.MyBase or not State.MyBase.Parent then return end
        local char=LP.Character; if not char then return end
        local hrp=char:FindFirstChild("HumanoidRootPart"); if not hrp then return end
        local search=State.MyBase:FindFirstChild("Slots") or State.MyBase
        for _,d in ipairs(search:GetDescendants()) do
            if d:IsA("BasePart") and d:FindFirstChild("TouchInterest") then
                pcall(function()
                    if firetouchinterest then firetouchinterest(hrp,d,0) firetouchinterest(hrp,d,1) end
                end)
            end
        end
        State.MoneyCollectCount=State.MoneyCollectCount+1
    end

    task.spawn(function() while true do if State.AutoCollect and State.MyBase then pcall(CollectSlots) end task.wait(State.AutoCollectSpeed) end end)
    task.spawn(function() while true do if State.AutoRebirth then pcall(function() local r=game:GetService("ReplicatedStorage").RemoteFunctions.Rebirth:InvokeServer() if r then State.RebirthCount=State.RebirthCount+1 end end) end task.wait(State.RebirthSpeed) end end)
    task.spawn(function() while true do if State.AutoUpgrade1 then pcall(function() game:GetService("ReplicatedStorage").RemoteFunctions.UpgradeSpeed:InvokeServer(1) State.Upgrade1Count=State.Upgrade1Count+1 end) end task.wait(State.UpgradeSpeed) end end)
    task.spawn(function() while true do if State.AutoUpgrade10 then pcall(function() game:GetService("ReplicatedStorage").RemoteFunctions.UpgradeSpeed:InvokeServer(10) State.Upgrade10Count=State.Upgrade10Count+1 end) end task.wait(State.UpgradeSpeed) end end)
    task.spawn(function() while true do if State.AutoUpgradeBase then pcall(function() game:GetService("ReplicatedStorage").Shared.Remotes.Networking["RE/Plots/PlotUpgradeBase"]:FireServer() State.UpgradeBaseCount=State.UpgradeBaseCount+1 end) end task.wait(State.UpgradeBaseSpeed) end end)
end

