do
    function Fn.ApplyFPSBoost()
        pcall(function() setfpscap(9999) end)
        local ff = {
            ["DFIntTaskSchedulerTargetFps"]="9999",
            ["FIntRenderShadowIntensity"]="0",
            ["DFIntCullFactorPixelThresholdShadowMapHighQuality"]="2147483647",
            ["DFIntCullFactorPixelThresholdShadowMapLowQuality"]="2147483647",
            ["FIntRenderShadowmapBias"]="75",
            ["DFIntCSGLevelOfDetailSwitchingDistance"]="0",
            ["FIntTerrainArraySliceSize"]="512",
            ["FIntDebugFRMQualityLevelOverride"]="1",
            ["DFIntTimestepArbiterThresholdCFLThou"]="300",
            ["DFFlagTextureQualityOverrideEnabled"]="True",
            ["DFIntTextureQualityOverride"]="1",
            ["DFFlagDisablePostProcessing"]="True",
        }
        for k,v in pairs(ff) do pcall(function() if setfflag then setfflag(k,v) end end) end
        local L = game:GetService("Lighting")
        pcall(function() L.GlobalShadows=false L.FogEnd=9e9 L.Brightness=0 end)
        pcall(function()
            settings().Rendering.QualityLevel = Enum.QualityLevel.Level01
            settings().Rendering.MeshPartDetailLevel = Enum.MeshPartDetailLevel.Level04
        end)
    end
    function Fn.RevertFPSBoost()
        local L = game:GetService("Lighting")
        pcall(function() L.GlobalShadows=true L.FogEnd=100000 L.Brightness=2 end)
        pcall(function()
            settings().Rendering.QualityLevel=Enum.QualityLevel.Automatic
            settings().Rendering.MeshPartDetailLevel=Enum.MeshPartDetailLevel.Level04
        end)
        pcall(function() setfpscap(60) end)
    end
    Fn.ApplyFPSBoost()
end

-- ─── FPS COUNTER ─────────────────────────────────────────────────────────────
RunService.RenderStepped:Connect(function()
    local t = tick()
    table.insert(FPSCounter.FrameTimes, 1, t)
    while #FPSCounter.FrameTimes > FPSCounter.MaxSamples do table.remove(FPSCounter.FrameTimes) end
    if #FPSCounter.FrameTimes >= 2 then
        local d = FPSCounter.FrameTimes[1] - FPSCounter.FrameTimes[#FPSCounter.FrameTimes]
        if d > 0 then FPSCounter.CurrentFPS = math.floor((#FPSCounter.FrameTimes-1)/d) end
    end
end)

