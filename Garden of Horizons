local function getSnapshotKey(tbl) local keys={}; for k in pairs(tbl) do table.insert(keys,k) end; table.sort(keys); return table.concat(keys,"|") end
local function startAutoRefresh()
	task.spawn(function()
		local lastBrainrotKey = ""
		local lastLuckyKey = ""
		while ScreenGui and ScreenGui.Parent do
			local brainrotFolders = scanRarityFolders()
			local brainrotKey = table.concat(brainrotFolders, "|")
			local luckyRarities = scanLuckyBlockRarities()
			local luckyKey = table.concat(luckyRarities, "|")

			if brainrotKey ~= lastBrainrotKey then
				local saved = {}; for n,v in pairs(ST.brainrotSelectedRarities) do saved[n]=v end
				refreshBrainrotFolders()
				for n,v in pairs(saved) do
					if v and ST.brainrotCheckboxes[n] then
						ST.brainrotSelectedRarities[n]=true
						ST.brainrotCheckboxes[n].Check.Text="Y"
						ST.brainrotCheckboxes[n].Check.BackgroundColor3=Color3.fromRGB(40,100,40)
					end
				end
				lastBrainrotKey = brainrotKey
			else
				for n,d in pairs(ST.brainrotCheckboxes) do
					local f=CFG.BRAINROT_PATH:FindFirstChild(n)
					d.CountLabel.Text = f and tostring(#f:GetChildren()) or "0"
				end
			end

			if luckyKey ~= lastLuckyKey then
				local saved = {}; for n,v in pairs(ST.luckyBlockSelectedRarities) do saved[n]=v end
				refreshLuckyBlockRarities()
				for n,v in pairs(saved) do
					if v and ST.luckyBlockCheckboxes[n] then
						ST.luckyBlockSelectedRarities[n]=true
						ST.luckyBlockCheckboxes[n].Check.Text="Y"
						ST.luckyBlockCheckboxes[n].Check.BackgroundColor3=Color3.fromRGB(100,80,0)
					end
				end
				lastLuckyKey = luckyKey
			else
				for n,d in pairs(ST.luckyBlockCheckboxes) do
					d.CountLabel.Text = tostring(getLuckyBlockRarityCount(n))
				end
			end

			updateFloorLabel()
			task.wait(1)
		end
	end)
end

--// ===================== FARMING (uses fullGrabObject) ===================== --
local function startFarming()
	if ST.running or ST.returning then return end; ST.running=true; ST.farmingTab=ST.activeTab
	if not ST.savedCFrame then saveCurrentPosition(); updateSavedPosLabel(); UI.LogLabel.Text="Auto-saved" end
	enableNoclip(); lockPhysics(); clearFloors(); updateFloorLabel()
	UI.StatusLabel.Text="Running..."; UI.ToggleBtn.Text="STOP"; UI.ToggleBtn.BackgroundColor3=Color3.fromRGB(180,40,40)
	task.spawn(function()
		refreshChar(); smoothTween(CFrame.new(rootPart.Position.X,rootPart.Position.Y+CFG.TRAVEL_DEPTH,rootPart.Position.Z),CFG.DIVE_SPEED)
		while ST.running do
			if ST.trialInProgress or ST.trialCollecting then task.wait(1); continue end; if not ST.running then break end
			refreshChar(); checkMapChange()
			if not hasSelectedRarities(ST.farmingTab) then UI.StatusLabel.Text="No rarity!"; task.wait(1); continue end
			local targets=getTargets(ST.farmingTab); if #targets==0 then UI.StatusLabel.Text="No targets..."; task.wait(1); continue end
			for _,target in ipairs(targets) do
				if not ST.running then break end
				if not target.Part or not target.Part.Parent or not target.Object or not target.Object.Parent then continue end
				refreshChar(); local tp=target.Part.CFrame.Position
				UI.PhaseLabel.Text="Travel -> "..target.Name; UI.StatusLabel.Text="["..target.Rarity.."] "..target.Name
				if not smoothTween(CFrame.new(tp.X,tp.Y+CFG.TRAVEL_DEPTH,tp.Z),CFG.TWEEN_SPEED) then break end; if not ST.running then break end; task.wait(0.05)
				if ST.waveCheckEnabled and target.Part and target.Part.Parent then
					if isWaveApproaching(target.Part.CFrame.Position,CFG.WAVE_SAFE_DISTANCE) then waitForWavesToClear(target.Part.CFrame.Position,function(m) UI.PhaseLabel.Text=m end)
						if not ST.running or not target.Part or not target.Part.Parent then break end; task.wait(0.2) end end
				if not ST.running then break end; if not target.Part or not target.Part.Parent then continue end
				local fp2=target.Part.CFrame.Position
				if not smoothTween(CFrame.new(fp2.X,fp2.Y+CFG.GRAB_HEIGHT,fp2.Z),CFG.RISE_SPEED) then break end; if not ST.running then break end
				if ST.waveCheckEnabled and isWaveNearby(rootPart.Position,CFG.WAVE_SAFE_DISTANCE*0.5) then smoothTween(CFrame.new(rootPart.Position.X,rootPart.Position.Y+CFG.TRAVEL_DEPTH,rootPart.Position.Z),CFG.DIVE_SPEED*2); task.wait(0.5); continue end
				UI.PhaseLabel.Text="Grabbing!"
				fullGrabObject(target.Object, target.Part, tp)
				ST.totalGrabbed+=1; UI.GrabLabel.Text="Grabbed: "..ST.totalGrabbed; UI.LogLabel.Text="["..target.Rarity.."] "..target.Name
				task.wait(CFG.WAIT_AT_TARGET); if not ST.running then break end
				UI.PhaseLabel.Text="Diving..."; refreshChar()
				smoothTween(CFrame.new(rootPart.Position.X,rootPart.Position.Y+CFG.TRAVEL_DEPTH,rootPart.Position.Z),CFG.DIVE_SPEED); task.wait(0.05)
			end
			if not ST.running then break end; if not CFG.AUTO_LOOP then ST.running=false; break end; task.wait(0.3) end
		if not ST.returning and not ST.autoTrialRunning then
			restoreFloors(); updateFloorLabel(); unlockPhysics(); disableNoclip()
			UI.ToggleBtn.Text="START"; UI.ToggleBtn.BackgroundColor3=Color3.fromRGB(40,140,40); UI.StatusLabel.Text="Stopped"; UI.PhaseLabel.Text="--" end
	end)
end

