--// ===================== PICKUP (uses fullGrabObject) ===================== --
local function pickupOneBrainrot(target)
	if not target.Part or not target.Part.Parent or not target.Object or not target.Object.Parent then return false end
	refreshChar()
	local tp = target.Part.CFrame.Position
	local objectRef = target.Object

	smoothTween(CFrame.new(rootPart.Position.X,rootPart.Position.Y+CFG.TRAVEL_DEPTH,rootPart.Position.Z),CFG.DIVE_SPEED); task.wait(0.05)
	if not ST.autoTrialEnabled then return false end
	smoothTween(CFrame.new(tp.X,tp.Y+CFG.TRAVEL_DEPTH,tp.Z),CFG.TWEEN_SPEED); task.wait(0.05)
	if not ST.autoTrialEnabled or not target.Part or not target.Part.Parent then return false end

	local fp = target.Part.CFrame.Position
	if ST.waveCheckEnabled and isWaveApproaching(fp,CFG.WAVE_SAFE_DISTANCE) then
		waitForWavesToClear(fp,function() end)
		if not ST.autoTrialEnabled or not target.Part or not target.Part.Parent then return false end
		task.wait(0.2)
	end
	if not target.Part or not target.Part.Parent then return false end

	local fp2 = target.Part.CFrame.Position
	smoothTween(CFrame.new(fp2.X,fp2.Y+CFG.GRAB_HEIGHT,fp2.Z),CFG.RISE_SPEED)

	if ST.waveCheckEnabled and isWaveNearby(rootPart.Position,CFG.WAVE_SAFE_DISTANCE*0.5) then
		smoothTween(CFrame.new(rootPart.Position.X,rootPart.Position.Y+CFG.TRAVEL_DEPTH,rootPart.Position.Z),CFG.DIVE_SPEED*2)
		task.wait(0.5); return false
	end

	fullGrabObject(target.Object, target.Part, tp)

	task.wait(0.5)
	if objectRef and objectRef.Parent ~= nil then
		if UI.PhaseLabel then UI.PhaseLabel.Text = "Retry grab..." end
		fullGrabObject(objectRef, target.Part and target.Part.Parent and target.Part or nil, tp)
		task.wait(0.5)
		if objectRef and objectRef.Parent ~= nil then
			if UI.PhaseLabel then UI.PhaseLabel.Text = "Grab failed!" end
			if UI.LogLabel then UI.LogLabel.Text = "Miss: "..target.Name end
			return false
		end
	end

	return true
end

--// ===================== TRIAL ===================== --
local function doOneTrialRun()
	ST.trialInProgress=true; ST.trialGrabbed=0; ST.trialCollecting=false; resetRarityTracker()
	enableNoclip(); lockPhysics(); clearFloors(); updateFloorLabel(); saveCurrentSelections(); switchTab("Brainrot")
	travelToTower(); task.wait(0.3); updateTrialTimerDisplay()
	local onCd=isTrialOnCooldown(); if onCd then restorePreviousSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress=false; return false,"cooldown" end
	if not isTrialTimerActive() then fireTrialPrompt(); task.wait(1.5); updateTrialTimerDisplay() end; task.wait(0.5)
	local dr,dc,_,di=scanWithRetry(6,0.4)
	if not dr then restorePreviousSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress=false; return false,"no_rarity" end
	local fn=matchRarityToFolder(dr); if not fn then restorePreviousSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress=false; return false,"no_folder" end
	ST.currentTrialRarity=dr; ST.currentTrialFolder=fn; ST.trialRequired=dc or 1; ST.trialCollecting=true; autoSelectTrialRarity(fn); updateTrackerLabel(); startContinuousTracker()
	UI.TrialStatusLabel.Text=string.format("Need %d %s",ST.trialRequired,fn); UI.TrialStatusLabel.TextColor3=Color3.fromRGB(0,255,100)
	local ts=tick()
	while ST.autoTrialEnabled and (tick()-ts)<CFG.TRIAL_TIME_LIMIT do
		refreshChar(); checkMapChange(); updateTrialTimerDisplay(); updateTrackerLabel()
		local it=getBrainrots({ST.currentTrialFolder})
		if #it==0 then task.wait(1.5); if not isTrialTimerActive() and not scanTrialFromBillboard() then
			stopContinuousTracker(); restorePreviousSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress=false; ST.trialCollecting=false; return true,"completed" end; continue end
		local bc,at=0,0
		while bc<CFG.TRIAL_BATCH_SIZE and at<CFG.TRIAL_BATCH_SIZE+4 do at+=1
			if not ST.autoTrialEnabled or (tick()-ts)>=CFG.TRIAL_TIME_LIMIT then break end
			refreshChar()
			local bt=getBrainrots({ST.currentTrialFolder}); if #bt==0 then break end
			local tg=nil
			for _,t in ipairs(bt) do
				if t.Part and t.Part.Parent and t.Object and t.Object.Parent then tg=t; break end
			end
			if not tg then break end
			if UI.PhaseLabel then UI.PhaseLabel.Text = "Grabbing: "..tg.Name end
			local grabbed = pickupOneBrainrot(tg)
			if grabbed then
				bc+=1; ST.trialGrabbed+=1; ST.totalGrabbed+=1
				UI.GrabLabel.Text="Grabbed: "..ST.totalGrabbed
				if UI.LogLabel then UI.LogLabel.Text = "Got: "..tg.Name end
			else
				task.wait(0.3)
			end
			if not ST.autoTrialEnabled then break end
			task.wait(0.1)
		end
		if bc>0 then travelToTower(); task.wait(0.2)
			for dn=1,bc+1 do fireTrialPrompt(); task.wait(0.3); if not ST.autoTrialEnabled then break end end
			if not ST.autoTrialEnabled then break end
			local nr,nc,ss=trackerRescanAtTower()
			if ss=="completed" then stopContinuousTracker(); restorePreviousSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress=false; ST.trialCollecting=false; return true,"completed"
			elseif ss=="changed" then updateTrackerLabel(); task.wait(0.3) elseif ss=="same" then ST.trialRequired=nc or 1; updateTrackerLabel() end
		else task.wait(0.5) end
		if not ST.autoTrialEnabled then break end; task.wait(0.2) end
	stopContinuousTracker(); restorePreviousSelections(); restoreFloors(); updateFloorLabel(); ST.trialInProgress=false; ST.trialCollecting=false; return true,"timeout"
end

local function startAutoTrialLoop()
	if ST.autoTrialRunning then return end; ST.autoTrialEnabled=true; ST.autoTrialRunning=true
	if not ST.savedCFrame then saveCurrentPosition(); updateSavedPosLabel() end
	UI.TrialStatusLabel.Text="Trial: ACTIVE"; UI.TrialStatusLabel.TextColor3=Color3.fromRGB(0,200,255)
	task.spawn(function() enableNoclip(); lockPhysics()
		while ST.autoTrialEnabled do
			local wf=ST.running; if wf then ST.running=false; stopTween(); task.wait(0.5) end
			doOneTrialRun(); stopContinuousTracker(); restoreFloors(); updateFloorLabel()
			if ST.savedCFrame and ST.autoTrialEnabled then ST.returning=true; smoothReturnToSaved(); ST.returning=false; task.wait(0.3) end
			if ST.savedTrialTab and ST.autoTrialEnabled then switchTab(ST.savedTrialTab) end
			if wf and ST.autoTrialEnabled then ST.running=true end; if not ST.autoTrialEnabled then break end
			local wt=CFG.TRIAL_COOLDOWN_WAIT; for i=wt,1,-1 do if not ST.autoTrialEnabled then break end; updateTrialTimerDisplay(); task.wait(1) end end
		ST.autoTrialRunning=false; stopContinuousTracker(); restoreFloors(); updateFloorLabel()
		if not ST.running then unlockPhysics(); disableNoclip() end end)
end

