do
    function Fn.Tween(obj, props, dur, style, dir)
        local t = TweenService:Create(obj,
            TweenInfo.new(dur or 0.2, style or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out),
            props)
        t:Play(); return t
    end

    function Fn.Corner(p, r)
        local c = Instance.new("UICorner")
        c.CornerRadius = UDim.new(0, r or 8)
        c.Parent = p; return c
    end

    function Fn.Pad(p, t, b, l, r)
        local pad = Instance.new("UIPadding")
        pad.PaddingTop    = UDim.new(0, t or 0)
        pad.PaddingBottom = UDim.new(0, b or 0)
        pad.PaddingLeft   = UDim.new(0, l or 0)
        pad.PaddingRight  = UDim.new(0, r or 0)
        pad.Parent = p; return pad
    end

    function Fn.Border(p, color, thick)
        local s = Instance.new("UIStroke")
        s.Color = color or C.Border
        s.Thickness = thick or 1
        s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        s.Transparency = 0
        s.Parent = p; return s
    end

    function Fn.FS(s)
        return math.floor(s * State.FontMult)
    end

    function Fn.Ripple(btn)
        btn.ClipsDescendants = true
        btn.MouseButton1Click:Connect(function()
            local r = Instance.new("Frame")
            r.Size = UDim2.new(0,0,0,0)
            r.Position = UDim2.new(0.5,0,0.5,0)
            r.AnchorPoint = Vector2.new(0.5,0.5)
            r.BackgroundColor3 = Color3.new(1,1,1)
            r.BackgroundTransparency = 0.82
            r.BorderSizePixel = 0
            r.ZIndex = btn.ZIndex + 5
            r.Parent = btn
            Fn.Corner(r, 999)
            local s = math.max(btn.AbsoluteSize.X, btn.AbsoluteSize.Y) * 2.8
            Fn.Tween(r, {Size=UDim2.new(0,s,0,s), BackgroundTransparency=1}, 0.5)
            task.delay(0.5, function() if r then r:Destroy() end end)
        end)
    end

    function Fn.Hover(btn, base, hover, prop)
        if State.IsMobile then return end
        prop = prop or "BackgroundColor3"
        btn.MouseEnter:Connect(function() Fn.Tween(btn, {[prop]=hover}, 0.1) end)
        btn.MouseLeave:Connect(function() Fn.Tween(btn, {[prop]=base}, 0.1) end)
    end

    function Fn.AccentBorder(p, a, b)
        local s = Fn.Border(p, a or C.Accent, 1)
        task.spawn(function()
            local t = 0
            while s and s.Parent do
                t = t + 0.012
                s.Color = (a or C.Accent):Lerp(b or C.AccentGlow, (math.sin(t)+1)/2)
                task.wait(0.04)
            end
        end)
        return s
    end

    function Fn.Sep(parent, label, color)
        local f = Instance.new("Frame")
        f.Size = UDim2.new(1, 0, 0, label and 26 or 10)
        f.BackgroundTransparency = 1
        f.Parent = parent

        local line = Instance.new("Frame")
        line.BackgroundColor3 = color or C.Border
        line.BorderSizePixel = 0
        line.BackgroundTransparency = 0
        line.Parent = f

        if label then
            line.Size  = UDim2.new(1,-100, 0, 1)
            line.Position = UDim2.new(0, 0, 0.5, 0)
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(0, 90, 1, 0)
            lbl.Position = UDim2.new(1, -90, 0, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = label
            lbl.TextColor3 = color or C.TextMuted
            lbl.TextSize = Fn.FS(9)
            lbl.Font = Enum.Font.GothamBlack
            lbl.TextXAlignment = Enum.TextXAlignment.Right
            lbl.Parent = f
        else
            line.Size = UDim2.new(1, 0, 0, 1)
            line.Position = UDim2.new(0, 0, 0.5, 0)
        end
        return f
    end

    function Fn.Scroll(parent, color)
        local s = Instance.new("ScrollingFrame")
        s.Size = UDim2.new(1,0,1,0)
        s.BackgroundTransparency = 1
        s.BorderSizePixel = 0
        s.ScrollBarThickness = 2
        s.ScrollBarImageColor3 = color or C.Accent
        s.ScrollBarImageTransparency = 0.4
        s.CanvasSize = UDim2.new(0,0,0,0)
        s.AutomaticCanvasSize = Enum.AutomaticSize.Y
        s.ScrollingDirection = Enum.ScrollingDirection.Y
        s.Parent = parent
        local l = Instance.new("UIListLayout")
        l.Padding = UDim.new(0, 3)
        l.Parent = s
        Fn.Pad(s, 2, 8, 0, 2)
        return s
    end
end

