local function getTsunamiParts() local p={}; if not CFG.TSUNAMI_PATH or not CFG.TSUNAMI_PATH.Parent then return p end; for _,o in pairs(CFG.TSUNAMI_PATH:GetDescendants()) do if o:IsA("BasePart") then table.insert(p,o) end end; return p end
local function getClosestWaveDistance(pos) local cl=math.huge; for _,p in pairs(getTsunamiParts()) do if p and p.Parent then local d=(p.Position-pos).Magnitude; if d<cl then cl=d end end end; return cl end
local function isWaveNearby(pos, sd) return getClosestWaveDistance(pos) < (sd or CFG.WAVE_SAFE_DISTANCE) end
local function isWaveApproaching(tp, cr) cr=cr or CFG.WAVE_SAFE_DISTANCE*1.5; for _,p in pairs(getTsunamiParts()) do if p and p.Parent and (p.Position-tp).Magnitude<cr then return true end end; return false end
local function waitForWavesToClear(tp, cb)
	local st=tick(); while true do if not isWaveApproaching(tp,CFG.WAVE_SAFE_DISTANCE) then return true end
		if tick()-st>CFG.WAVE_MAX_WAIT then return true end; if cb then cb("Wave nearby...") end; task.wait(CFG.WAVE_CHECK_INTERVAL)
		if not ST.running and not ST.autoTrialRunning and not ST.returning then return false end end
end

