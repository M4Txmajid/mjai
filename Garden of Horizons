        end

        -- Pill track
        local tw = State.IsMobile and 52 or 46
        local th = State.IsMobile and 26 or 24
        local pill = Instance.new("Frame")
        pill.Size = UDim2.new(0, tw, 0, th)
        pill.Position = UDim2.new(1, -(tw + 14), 0.5, -th / 2)
