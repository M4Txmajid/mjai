--// ===================== IMPROVED PROMPTS ===================== --
local function fireProximityPrompt(prompt)
	if not prompt or not prompt:IsA("ProximityPrompt") then return end
	local oh = prompt.HoldDuration
	local od = prompt.MaxActivationDistance
	local oe = prompt.Enabled
	local ox = prompt.Exclusivity
	prompt.HoldDuration = 0
	prompt.MaxActivationDistance = CFG.PROMPT_OVERRIDE_DISTANCE
	prompt.Enabled = true
	prompt.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
	pcall(function() prompt:InputHoldBegin() end)
	pcall(function() prompt:InputHoldEnd() end)
	pcall(function()
		local ProximityPromptService = game:GetService("ProximityPromptService")
		ProximityPromptService:TriggerPrompt(prompt)
	end)
	local parentPart = prompt.Parent
	if parentPart and parentPart:IsA("BasePart") and rootPart and rootPart.Parent then
		pcall(function()
			firetouchinterest(rootPart, parentPart, 0)
			firetouchinterest(rootPart, parentPart, 1)
		end)
	end
	task.delay(0.15, function()
		if prompt and prompt.Parent then
			prompt.HoldDuration = oh
			prompt.MaxActivationDistance = od
			prompt.Enabled = oe
			prompt.Exclusivity = ox
		end
	end)
end

local function grabAllPrompts(obj)
	if not obj or not obj.Parent then return 0 end
	local fired = {}
	local function fireOnce(p)
		if not p or not p:IsA("ProximityPrompt") or fired[p] then return end
		fired[p] = true
		fireProximityPrompt(p)
	end
	if obj:IsA("ProximityPrompt") then fireOnce(obj) end
	for _, d in pairs(obj:GetDescendants()) do fireOnce(d) end
	if obj.Parent then for _, ch in pairs(obj.Parent:GetChildren()) do fireOnce(ch) end end
	task.wait(0.08)
	for p in pairs(fired) do
		pcall(function() p:InputHoldBegin() end)
		pcall(function() p:InputHoldEnd() end)
	end
	return 0
end

local function grabNearbyPrompts(pos, rad)
	rad = rad or 25
	local list = {}
	for _, d in pairs(workspace:GetDescendants()) do
		if d:IsA("ProximityPrompt") then
			local p = d.Parent
			if p and p:IsA("BasePart") then
				local dist = (p.Position - pos).Magnitude
				if dist <= rad then
					table.insert(list, {prompt = d, dist = dist})
				end
			end
		end
	end
	table.sort(list, function(a, b) return a.dist < b.dist end)
	for _, entry in ipairs(list) do
		fireProximityPrompt(entry.prompt)
	end
	task.wait(0.08)
	for _, entry in ipairs(list) do
		if entry.prompt and entry.prompt.Parent then
			pcall(function() entry.prompt:InputHoldBegin() end)
			pcall(function() entry.prompt:InputHoldEnd() end)
		end
	end
	return #list
end

local function fullGrabObject(obj, targetPart, pos)
	if not obj or not obj.Parent then return end
	if targetPart and targetPart.Parent and rootPart and rootPart.Parent then
		if ST.bodyVel and ST.bodyVel.Parent then ST.bodyVel.MaxForce = Vector3.zero end
		rootPart.CFrame = targetPart.CFrame * CFrame.new(0, 2, 0)
		rootPart.Velocity = Vector3.zero
		rootPart.AssemblyLinearVelocity = Vector3.zero
		if ST.bodyVel and ST.bodyVel.Parent then ST.bodyVel.MaxForce = Vector3.new(1e9,1e9,1e9); ST.bodyVel.Velocity = Vector3.zero end
	end
	task.wait(0.05)
	grabAllPrompts(obj)
	grabNearbyPrompts(pos or (targetPart and targetPart.Position or Vector3.zero), 20)
	pcall(function()
		for _, p in pairs(obj:GetDescendants()) do
			if p:IsA("BasePart") then
				firetouchinterest(rootPart, p, 0)
				task.wait()
				firetouchinterest(rootPart, p, 1)
			end
		end
		if targetPart and targetPart.Parent then
			firetouchinterest(rootPart, targetPart, 0)
			task.wait()
			firetouchinterest(rootPart, targetPart, 1)
		end
	end)
	pcall(function()
		for _, d in pairs(obj:GetDescendants()) do
			if d:IsA("ClickDetector") then fireclickdetector(d) end
		end
	end)
	task.wait(0.08)
	grabAllPrompts(obj)
	grabNearbyPrompts(pos or (targetPart and targetPart.Position or Vector3.zero), 20)
end

