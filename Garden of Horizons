local function extractRarityFromText(text)
	if not text or #text == 0 then return nil, nil end
	local lower = string.lower(text)
	if string.find(lower, "time remaining") or string.find(lower, "cooldown") or string.find(lower, "seconds left") or string.find(lower, "minutes left") then return nil, nil end
	if string.find(lower, "waiting") and not string.find(lower, "bring") then return nil, nil end
	if lower:match("^%s*%d+%s*$") or lower:match("^%s*%d+:%d+%s*$") then return nil, nil end
	if lower:match("^%s*%d+:%d+") or lower:match("^%s*%d+s%s*$") then return nil, nil end
	for _, kw in ipairs(RARITY_KEYWORDS) do
		if string.find(lower, kw, 1, true) then
			local c = nil
			c = c or tonumber(lower:match("(%d+)%s*x?%s*"..kw))
			c = c or tonumber(lower:match(kw.."%s*[x:%-]?%s*(%d+)"))
			c = c or tonumber(lower:match("[%(%[](%d+)[%)%]]"))
			c = c or tonumber(lower:match("x(%d+)"))
			if not c then
				for num in lower:gmatch("(%d+)") do
					local n = tonumber(num)
					if n and n >= 1 and n <= 99 then c = n; break end
				end
			end
			return kw, c or 1
		end
	end
	return nil, nil
end

local function readInfoFrameDirect()
	local ok, info = pcall(function()
		return workspace.GameObjects.PlaceSpecific.root.Tower.Main.Billboard.BillboardGui.Frame.Info
	end)
	if not ok or not info or not info.Parent then return nil, nil, nil end

	local best, bestPri = nil, 999
	for _, desc in pairs(info:GetDescendants()) do
		if desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox") then
			local text = desc.Text
			if not text or #text < 2 then continue end
			local lower = string.lower(text)

			local inTimer = false
			local par = desc.Parent
			while par and par ~= info do
				local pn = string.lower(par.Name)
				if string.find(pn,"timer",1,true) or string.find(pn,"cooldown",1,true) or string.find(pn,"countdown",1,true) then
					inTimer = true; break
				end
				par = par.Parent
			end
			if inTimer then continue end

			if lower:match("^%s*%d+%s*$") then continue end
			if lower:match("^%s*%d+:%d+") then continue end
			if lower:match("^%s*%d+s%s*$") then continue end
			if string.find(lower,"time remaining",1,true) then continue end
			if string.find(lower,"cooldown",1,true) then continue end
			if string.find(lower,"seconds left",1,true) then continue end
			if string.find(lower,"time",1,true) and string.find(lower,"%d") and not string.find(lower,"bring",1,true) and not string.find(lower,"collect",1,true) and not string.find(lower,"deliver",1,true) and not string.find(lower,"need",1,true) then continue end

			local r, c = extractRarityFromText(text)
			if r then
				local pri = 50
				if     string.find(lower,"bring",1,true)    then pri = 1
				elseif string.find(lower,"collect",1,true)  then pri = 2
				elseif string.find(lower,"deliver",1,true)  then pri = 3
				elseif string.find(lower,"need",1,true)     then pri = 4
				elseif string.find(lower,"gather",1,true)   then pri = 5
				elseif string.find(lower,"find",1,true)     then pri = 6
				elseif string.find(lower,"get",1,true)      then pri = 7
				elseif string.find(lower,"brainrot",1,true) then pri = 8
				end
				if pri < bestPri then bestPri = pri; best = {rarity=r, count=c, text=text} end
			end
		end
	end
	if best then return best.rarity, best.count, best.text end
	return nil, nil, nil
end

local function scanTrialFromBillboard()
	local r, c, t = readInfoFrameDirect()
	if r then return r, c, t, "[DIRECT]" end

	local pg = player:FindFirstChild("PlayerGui")
	if pg then local bm, bp = nil, 999
		for _, desc in pairs(pg:GetDescendants()) do
			if (desc:IsA("TextLabel") or desc:IsA("TextButton")) and desc.Visible then
				local text = desc.Text; if text and #text > 2 then local lower = string.lower(text)
					local isTR = string.find(lower,"trial",1,true) or string.find(lower,"bring",1,true) or string.find(lower,"collect",1,true) or string.find(lower,"tsunami",1,true) or string.find(lower,"deliver",1,true) or (string.find(lower,"need",1,true) and string.find(lower,"brainrot",1,true))
					if not isTR then local p = desc.Parent; while p and p ~= pg do local pn = string.lower(p.Name)
						if string.find(pn,"trial",1,true) or string.find(pn,"tsunami",1,true) or string.find(pn,"tower",1,true) or string.find(pn,"quest",1,true) then isTR = true; break end; p = p.Parent end end
					if isTR then local rv, cv = extractRarityFromText(text)
						if rv then local pri = 50
							if string.find(lower,"bring",1,true) then pri=1 elseif string.find(lower,"collect",1,true) then pri=2
							elseif string.find(lower,"deliver",1,true) then pri=3 elseif string.find(lower,"need",1,true) then pri=4 end
							if pri < bp then bp = pri; bm = {rarity=rv,count=cv,text=text} end end end
				end
			end
		end
		if bm then return bm.rarity, bm.count, bm.text, "[GUI_FALLBACK]" end
	end
	return nil, nil, nil, "[NONE]"
end

local function scanWithRetry(ma, db)
	ma = ma or 6; db = db or 0.3; local res = {}
	for i = 1, ma do
		if not ST.autoTrialEnabled then return nil,nil,nil,"stopped" end
		local r,c,t,d = scanTrialFromBillboard()
		if r then
			res[r] = (res[r] or 0) + 1
			if res[r] >= 2 then return r,c,t,d end
		end
		if i < ma then task.wait(db) end
	end
	for i = 1, 4 do
		local r,c,t,d = scanTrialFromBillboard()
		if r then return r,c,t,d end
		task.wait(0.2)
	end
	return nil,nil,nil,"no_result"
end

local function isTrialOnCooldown()
	local cd = getCooldownContainer(); if not cd then return false,"" end
	local vis = true; pcall(function() vis = cd.Visible end); if not vis then return false,"" end
	local t = ""; for _, d in pairs(cd:GetDescendants()) do if d:IsA("TextLabel") and d.Visible and d.Text and #d.Text > 0 then t = t.." "..d.Text end end
	return #t > 0, t
end
local function isTrialTimerActive()
	local tm = getTrialTimerContainer(); if not tm then return false,"" end
	local vis = true; pcall(function() vis = tm.Visible end); if not vis then return false,"" end
	local t = ""; for _, d in pairs(tm:GetDescendants()) do if d:IsA("TextLabel") and d.Visible and d.Text and #d.Text > 0 then t = t.." "..d.Text end end
	if #t > 0 and string.find(t,"%d") then return true, t end; return false,""
end

local function matchRarityToFolder(kw)
	if not kw then return nil end; local lower = string.lower(kw)
	for _, c in pairs(CFG.BRAINROT_PATH:GetChildren()) do if (c:IsA("Folder") or c:IsA("Model")) and string.lower(c.Name)==lower then return c.Name end end
	for _, c in pairs(CFG.BRAINROT_PATH:GetChildren()) do if (c:IsA("Folder") or c:IsA("Model")) then local cn=string.lower(c.Name); if string.find(cn,lower,1,true) or string.find(lower,cn,1,true) then return c.Name end end end
	if #lower > 4 then local sh = lower:sub(1,-3)
		for _, c in pairs(CFG.BRAINROT_PATH:GetChildren()) do if (c:IsA("Folder") or c:IsA("Model")) then local cn=string.lower(c.Name); if string.find(cn,sh,1,true) or string.find(sh,cn,1,true) then return c.Name end end end end
	return nil
end

