do
    function Fn.CreateESP()
        local e={}; e.BoxLines={}
        for i=1,4 do
            local l=Drawing.new("Line")
            l.Visible=false l.Thickness=ESPConfig.BoxThickness
            table.insert(e.BoxLines,l)
        end
        for _,k in ipairs({"Name","Rarity","Distance"}) do
            e[k]=Drawing.new("Text")
            e[k].Visible=false e[k].Size=ESPConfig.TextSize
            e[k].Center=true e[k].Outline=true
            e[k].OutlineColor=Color3.fromRGB(0,0,0)
            e[k].Font=Drawing.Fonts.Plex
        end
        e.Rarity.Size=ESPConfig.TextSize-2
        e.Distance.Size=ESPConfig.TextSize-2
        e.Distance.Color=Color3.fromRGB(180,180,180)
        e.Tracer=Drawing.new("Line")
        e.Tracer.Visible=false
        e.Tracer.Thickness=ESPConfig.TracerThickness
        return e
    end

    function Fn.RemoveESP(e)
        if not e then return end
        for _,l in pairs(e.BoxLines or {}) do pcall(function() l:Remove() end) end
        for _,k in ipairs({"Name","Rarity","Distance","Tracer"}) do pcall(function() e[k]:Remove() end) end
    end

    function Fn.HideESP(e)
        if not e then return end
        for _,l in pairs(e.BoxLines) do l.Visible=false end
        e.Name.Visible=false e.Rarity.Visible=false e.Distance.Visible=false e.Tracer.Visible=false
    end

    local function GetBrainrotInfo(b)
        local p = b:FindFirstChild("HumanoidRootPart") or b:FindFirstChild("Head") or b:FindFirstChildWhichIsA("BasePart")
        if not p then
            local r=b:FindFirstChild("RenderBrainrot")
            if r then p=r:FindFirstChild("HumanoidRootPart") or r:FindFirstChild("Head") or r:FindFirstChildWhichIsA("BasePart") end
        end
        if not p then return nil end
        local ok,cf,sz=pcall(function() return b:GetBoundingBox() end)
        if not ok then cf=p.CFrame sz=p.Size end
        return {Position=cf.Position, Size=sz}
    end

    function Fn.UpdateESP(brainrot, esp, folder, name)
        if not ESPConfig.Enabled then Fn.HideESP(esp) return end
        if not brainrot or not brainrot.Parent then Fn.HideESP(esp) return end
        if Fn.NothingESPSelected() then Fn.HideESP(esp) return end
        if not Fn.IsESPSelected(folder, name) then Fn.HideESP(esp) return end
        local data=GetBrainrotInfo(brainrot)
        if not data then Fn.HideESP(esp) return end
        local char=LP.Character
        if not char or not char:FindFirstChild("HumanoidRootPart") then Fn.HideESP(esp) return end
        local dist=(char.HumanoidRootPart.Position-data.Position).Magnitude
        if dist>ESPConfig.MaxDistance then Fn.HideESP(esp) return end
        local sp,onScreen=Camera:WorldToViewportPoint(data.Position)
        local color=Fn.GetRarityColor(folder)
        if not onScreen then
            for _,l in pairs(esp.BoxLines) do l.Visible=false end
            esp.Name.Visible=false esp.Rarity.Visible=false esp.Distance.Visible=false
            if ESPConfig.ShowTracer then
                local bot=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
                esp.Tracer.From=bot
                esp.Tracer.To=Vector2.new(math.clamp(sp.X,0,Camera.ViewportSize.X),math.clamp(sp.Y,0,Camera.ViewportSize.Y))
                esp.Tracer.Color=color esp.Tracer.Visible=true
            else esp.Tracer.Visible=false end
            return
        end
        local topW=Camera:WorldToViewportPoint(data.Position+Vector3.new(0,data.Size.Y/2,0))
        local botW=Camera:WorldToViewportPoint(data.Position-Vector3.new(0,data.Size.Y/2,0))
        local bH=math.abs(botW.Y-topW.Y) local bW=bH*0.6
        local bx=sp.X-bW/2 local by=topW.Y
        local tl=Vector2.new(bx,by) local tr=Vector2.new(bx+bW,by)
        local bl=Vector2.new(bx,by+bH) local br=Vector2.new(bx+bW,by+bH)
        if ESPConfig.ShowBox then
            esp.BoxLines[1].From=tl esp.BoxLines[1].To=tr
            esp.BoxLines[2].From=tr esp.BoxLines[2].To=br
            esp.BoxLines[3].From=br esp.BoxLines[3].To=bl
            esp.BoxLines[4].From=bl esp.BoxLines[4].To=tl
            for _,l in pairs(esp.BoxLines) do l.Color=color l.Thickness=ESPConfig.BoxThickness l.Visible=true end
        else for _,l in pairs(esp.BoxLines) do l.Visible=false end end
        local yOff=by-ESPConfig.TextSize-4
        if ESPConfig.ShowName then esp.Name.Text=name esp.Name.Position=Vector2.new(sp.X,yOff) esp.Name.Color=Color3.new(1,1,1) esp.Name.Visible=true yOff=yOff-ESPConfig.TextSize else esp.Name.Visible=false end
        if ESPConfig.ShowRarity then esp.Rarity.Text="["..folder.."]" esp.Rarity.Position=Vector2.new(sp.X,yOff) esp.Rarity.Color=color esp.Rarity.Visible=true else esp.Rarity.Visible=false end
        if ESPConfig.ShowDistance then esp.Distance.Text=string.format("[%d studs]",math.floor(dist)) esp.Distance.Position=Vector2.new(sp.X,by+bH+2) esp.Distance.Visible=true else esp.Distance.Visible=false end
        if ESPConfig.ShowTracer then
            esp.Tracer.From=Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y)
            esp.Tracer.To=Vector2.new(sp.X,by+bH) esp.Tracer.Color=color esp.Tracer.Visible=true
        else esp.Tracer.Visible=false end
    end
end

