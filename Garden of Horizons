local function extractLuckyBlockRarity(name)
	if not name then return nil end
	local lower = string.lower(name)
	local fromSuffix = name:match("_(%w+)$")
	if fromSuffix and #fromSuffix > 2 then return fromSuffix end
	for _, kw in ipairs(RARITY_KEYWORDS) do
		if string.find(lower, kw, 1, true) then
			return kw:sub(1,1):upper()..kw:sub(2)
		end
	end
	local lastWord = name:match("[_%-%.%s](%w+)%s*$")
	if lastWord and #lastWord > 2 then return lastWord end
	return nil
end

