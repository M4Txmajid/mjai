-- // ESP TRACKING
-- ════════════════════════════════════════
do
    local function AddESP(b, folder)
        if ESPObjects[b] then return end
        ESPObjects[b]={esp=Fn.CreateESP(), folder=folder, realName=Fn.GetRealBrainrotName(b)}
    end
    local function RemESP(b)
        if not ESPObjects[b] then return end
        Fn.RemoveESP(ESPObjects[b].esp) ESPObjects[b]=nil
    end
    local function TrackFolder(folder)
        local fn=folder.Name
        for _,b in pairs(folder:GetChildren()) do if b:IsA("Model") then AddESP(b,fn) end end
        folder.ChildAdded:Connect(function(b) if b:IsA("Model") then task.wait(0.2) AddESP(b,fn) end end)
        folder.ChildRemoved:Connect(function(b) RemESP(b) end)
    end
    function Fn.InitESPTracking()
        local AB=workspace:FindFirstChild("ActiveBrainrots")
        if not AB then return end
        for _,c in pairs(AB:GetChildren()) do
            if c:IsA("Folder") then TrackFolder(c)
            elseif c:IsA("Model") then AddESP(c,"Uncategorized") end
        end
        AB.ChildAdded:Connect(function(c)
            task.wait(0.2)
            if c:IsA("Folder") then TrackFolder(c)
            elseif c:IsA("Model") then AddESP(c,"Uncategorized") end
        end)
        AB.ChildRemoved:Connect(function(c)
            if c:IsA("Folder") then for _,b in pairs(c:GetChildren()) do RemESP(b) end
            else RemESP(c) end
        end)
    end
end

