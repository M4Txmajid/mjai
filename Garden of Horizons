        knobShadow.Position = default and UDim2.new(1, -(ks / 2 + 5), 0.5, 0) or UDim2.new(0, (ks / 2 + 5), 0.5, 0)
        knobShadow.Parent = pill
        Fn.Corner(knobShadow, (ks + 4) / 2)

        -- Knob
        local knob = Instance.new("Frame")
        knob.Size = UDim2.new(0, ks, 0, ks)
        knob.AnchorPoint = Vector2.new(0.5, 0.5)
        knob.Position = default and UDim2.new(1, -(ks / 2 + 5), 0.5, 0) or UDim2.new(0, (ks / 2 + 5), 0.5, 0)
        knob.BackgroundColor3 = C.Text
        knob.BorderSizePixel = 0
        knob.ZIndex = 3
        knob.Parent = pill
