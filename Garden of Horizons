    -- ── FLY STATE ──────────────────────────────────────────────
    local FlyState = {
        enabled = false,
        speed = 100,
        bodyGyro = nil,
        bodyVelocity = nil,
        connection = nil,
    }

    local fly_upPressed    = false
    local fly_downPressed  = false
    local fly_joystickInput = Vector2.new(0, 0)
    local fly_joystickActive = false
    local fly_verticalInput = 0
    local FlyMobileFrame = nil

    local function StopFly()
        FlyState.enabled = false
        if FlyState.connection then FlyState.connection:Disconnect() FlyState.connection = nil end
        if FlyState.bodyVelocity and FlyState.bodyVelocity.Parent then FlyState.bodyVelocity:Destroy() FlyState.bodyVelocity = nil end
        if FlyState.bodyGyro and FlyState.bodyGyro.Parent then FlyState.bodyGyro:Destroy() FlyState.bodyGyro = nil end
        local char = LP.Character
        if char then
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum then hum.PlatformStand = false end
        end
        if FlyMobileFrame and FlyMobileFrame.Parent then
            TweenService:Create(FlyMobileFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
                Position = UDim2.new(0, 0, 1, 10)
            }):Play()
            task.delay(0.35, function()
                if FlyMobileFrame then FlyMobileFrame.Visible = false end
            end)
        end
    end

    local function StartFly()
        local char = LP.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hrp or not hum then return end

        FlyState.enabled = true

        for _, o in pairs(hrp:GetChildren()) do
            if o.Name == "_MD_FlyBG" or o.Name == "_MD_FlyBV" then o:Destroy() end
        end

        local bg = Instance.new("BodyGyro")
        bg.Name = "_MD_FlyBG"
        bg.P = 9e4
        bg.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
        bg.CFrame = hrp.CFrame
        bg.Parent = hrp
        FlyState.bodyGyro = bg

        local bv = Instance.new("BodyVelocity")
        bv.Name = "_MD_FlyBV"
        bv.Velocity = Vector3.zero
        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bv.Parent = hrp
        FlyState.bodyVelocity = bv

        if State.IsMobile and FlyMobileFrame then
            FlyMobileFrame.Visible = true
            FlyMobileFrame.Position = UDim2.new(0, 0, 1, 10)
            TweenService:Create(FlyMobileFrame, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                Position = UDim2.new(0, 0, 1, -210)
            }):Play()
        end

        if FlyState.connection then FlyState.connection:Disconnect() end
        FlyState.connection = RunService.Heartbeat:Connect(function()
            if not FlyState.enabled then return end
            local char2 = LP.Character; if not char2 then return end
            local hrp2 = char2:FindFirstChild("HumanoidRootPart"); if not hrp2 then return end
            if not FlyState.bodyVelocity or not FlyState.bodyVelocity.Parent then return end
            if not FlyState.bodyGyro    or not FlyState.bodyGyro.Parent    then return end

            local cam = workspace.CurrentCamera
            local moveDir = Vector3.zero

            if State.IsMobile then
                local char2 = LP.Character
                if char2 then
                    local hum2 = char2:FindFirstChildOfClass("Humanoid")
                    if hum2 then
                        local md = hum2.MoveDirection
                        if md.Magnitude > 0 then
                            moveDir = md
                        end
                    end
                end
            else
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then moveDir = moveDir + cam.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then moveDir = moveDir - cam.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then moveDir = moveDir - cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then moveDir = moveDir + cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space)      then moveDir = moveDir + Vector3.new(0,1,0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
                or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then moveDir = moveDir - Vector3.new(0,1,0) end
            end
            if moveDir.Magnitude > 0 then
                FlyState.bodyVelocity.Velocity = moveDir.Unit * FlyState.speed
            else
                FlyState.bodyVelocity.Velocity = Vector3.zero
            end
            FlyState.bodyGyro.CFrame = cam.CFrame
        end)
    end

