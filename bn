local AC_ResultFrames = {}

function AC_PopulateResults()
    for _, frame in pairs(AC_ResultFrames) do
        pcall(function() frame:Destroy() end)
    end
    AC_ResultFrames = {}

    if AC_TotalFound == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, 0, 0, 50)
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = AC_ScanComplete and "✅ No anti-cheat found!\nThis game may not have client-side AC." or "⏳ Run a scan first!\nPress 'FULL DEEP SCAN' above."
        emptyLabel.TextColor3 = AC_ScanComplete and Theme.Green or Theme.TextMuted
        emptyLabel.TextSize = FS(10)
        emptyLabel.Font = Enum.Font.GothamBold
        emptyLabel.TextWrapped = true
        emptyLabel.Parent = acResultsScroll
        table.insert(AC_ResultFrames, emptyLabel)
        return
    end

    -- Combine all
    local allResults = {}
    for _, e in ipairs(AC_ScanResults.Remotes) do table.insert(allResults, e) end
    for _, e in ipairs(AC_ScanResults.Scripts) do table.insert(allResults, e) end
    for _, e in ipairs(AC_ScanResults.Modules) do table.insert(allResults, e) end
    for _, e in ipairs(AC_ScanResults.Misc) do table.insert(allResults, e) end

    local function tSort(a, b)
        local order = {["🔴 HIGH"] = 1, ["🟣 SUSPICIOUS"] = 2, ["🟡 MEDIUM"] = 3, ["🟠 LOW"] = 4, ["⚪ UNKNOWN"] = 5}
        return (order[a.ThreatLevel] or 5) < (order[b.ThreatLevel] or 5)
    end
    table.sort(allResults, tSort)

    for i, entry in ipairs(allResults) do
        local cardH = IsMobile and 86 or 78
        local card = Instance.new("Frame")
        card.Size = UDim2.new(1, -4, 0, cardH)
        card.BackgroundColor3 = entry.Disabled and Color3.fromRGB(10, 30, 10) or (entry.Hooked and Color3.fromRGB(20, 10, 30) or Theme.BgLighter)
        card.BorderSizePixel = 0
        card.LayoutOrder = i
        card.Parent = acResultsScroll
        Corner(card, 6)
        Stroke(card, entry.Disabled and Theme.Green or (entry.Hooked and Theme.Purple or entry.ThreatColor), 1, 0.4)

        -- Threat bar
        local threatBar = Instance.new("Frame")
        threatBar.Size = UDim2.new(0, 4, 1, -8)
        threatBar.Position = UDim2.new(0, 4, 0, 4)
        threatBar.BackgroundColor3 = entry.ThreatColor
        threatBar.BorderSizePixel = 0
        threatBar.Parent = card
        Corner(threatBar, 2)

        -- Name
        local nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, -90, 0, 16)
        nameLabel.Position = UDim2.new(0, 14, 0, 3)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = entry.Category .. " " .. entry.Name
        nameLabel.TextColor3 = entry.Disabled and Theme.TextMuted or Theme.Text
        nameLabel.TextSize = FS(9)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextXAlignment = Enum.TextXAlignment.Left
        nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
        nameLabel.Parent = card

        -- Status badge
        local statusBadge = Instance.new("TextLabel")
        statusBadge.Size = UDim2.new(0, 75, 0, 14)
        statusBadge.Position = UDim2.new(1, -80, 0, 4)
        statusBadge.BackgroundColor3 = entry.Disabled and Theme.Green or (entry.Hooked and Theme.Purple or entry.ThreatColor)
        statusBadge.BackgroundTransparency = 0.5
        statusBadge.Text = entry.Disabled and "✅ OFF" or (entry.Hooked and "🔇 HOOKED" or entry.ThreatLevel)
        statusBadge.TextColor3 = Theme.Text
        statusBadge.TextSize = FS(7)
        statusBadge.Font = Enum.Font.GothamBold
        statusBadge.Parent = card
        Corner(statusBadge, 3)

        -- Path
        local pathLabel = Instance.new("TextLabel")
        pathLabel.Size = UDim2.new(1, -16, 0, 11)
        pathLabel.Position = UDim2.new(0, 14, 0, 20)
        pathLabel.BackgroundTransparency = 1
        pathLabel.Text = "📁 " .. entry.Path
        pathLabel.TextColor3 = Theme.TextMuted
        pathLabel.TextSize = FS(7)
        pathLabel.Font = Enum.Font.Gotham
        pathLabel.TextXAlignment = Enum.TextXAlignment.Left
        pathLabel.TextTruncate = Enum.TextTruncate.AtEnd
        pathLabel.Parent = card

        -- Keyword
        local keyLabel = Instance.new("TextLabel")
        keyLabel.Size = UDim2.new(1, -16, 0, 11)
        keyLabel.Position = UDim2.new(0, 14, 0, 33)
        keyLabel.BackgroundTransparency = 1
        keyLabel.Text = "🔑 " .. entry.MatchedKeyword
        keyLabel.TextColor3 = entry.ThreatColor
        keyLabel.TextSize = FS(7)
        keyLabel.Font = Enum.Font.Gotham
        keyLabel.TextXAlignment = Enum.TextXAlignment.Left
        keyLabel.Parent = card

        -- Action buttons
        if not entry.Disabled then
            local btnW = IsMobile and 65 or 56
            local btnHLocal = IsMobile and 24 or 20
            local btnY = IsMobile and 52 or 48

            local disBtn = Instance.new("TextButton")
            disBtn.Size = UDim2.new(0, btnW, 0, btnHLocal)
            disBtn.Position = UDim2.new(0, 14, 0, btnY)
            disBtn.BackgroundColor3 = Theme.Red
            disBtn.Text = "🗑️ Delete"
            disBtn.TextColor3 = Theme.Text
            disBtn.TextSize = FS(8)
            disBtn.Font = Enum.Font.GothamBold
            disBtn.BorderSizePixel = 0
            disBtn.Parent = card
            Corner(disBtn, 4)
            Ripple(disBtn)

            disBtn.MouseButton1Click:Connect(function()
                if AC_DisableItem(entry) then
                    disBtn.Text = "✅"
                    disBtn.BackgroundColor3 = Theme.Green
                    card.BackgroundColor3 = Color3.fromRGB(10, 30, 10)
                    statusBadge.Text = "✅ OFF"
                    statusBadge.BackgroundColor3 = Theme.Green
                    nameLabel.TextColor3 = Theme.TextMuted
                    AC_UpdateStats()
                end
            end)

            if entry.Instance and (entry.Instance:IsA("RemoteEvent") or entry.Instance:IsA("RemoteFunction")) and not entry.Hooked then
                local hookBtn = Instance.new("TextButton")
                hookBtn.Size = UDim2.new(0, btnW, 0, btnHLocal)
                hookBtn.Position = UDim2.new(0, 14 + btnW + 4, 0, btnY)
                hookBtn.BackgroundColor3 = Theme.Purple
                hookBtn.Text = "🔇 Hook"
                hookBtn.TextColor3 = Theme.Text
                hookBtn.TextSize = FS(8)
                hookBtn.Font = Enum.Font.GothamBold
                hookBtn.BorderSizePixel = 0
                hookBtn.Parent = card
                Corner(hookBtn, 4)
                Ripple(hookBtn)

                hookBtn.MouseButton1Click:Connect(function()
                    AC_HookRemote(entry)
                    AC_SetupNamecallHook()
                    hookBtn.Text = "✅"
                    hookBtn.BackgroundColor3 = Theme.Green
                    statusBadge.Text = "🔇 HOOKED"
                    statusBadge.BackgroundColor3 = Theme.Purple
                    card.BackgroundColor3 = Color3.fromRGB(20, 10, 30)
                    AC_UpdateStats()
                end)
            end

            local copyBtn = Instance.new("TextButton")
            copyBtn.Size = UDim2.new(0, btnW, 0, btnHLocal)
            copyBtn.Position = UDim2.new(1, -(btnW + 6), 0, btnY)
            copyBtn.BackgroundColor3 = Theme.Blue
            copyBtn.Text = "📋 Copy"
            copyBtn.TextColor3 = Theme.Text
            copyBtn.TextSize = FS(8)
            copyBtn.Font = Enum.Font.GothamBold
            copyBtn.BorderSizePixel = 0
            copyBtn.Parent = card
            Corner(copyBtn, 4)
            Ripple(copyBtn)

            copyBtn.MouseButton1Click:Connect(function()
                pcall(function() if setclipboard then setclipboard(entry.Path) end end)
                copyBtn.Text = "✅"
                task.delay(1, function() copyBtn.Text = "📋 Copy" end)
            end)
        end

        table.insert(AC_ResultFrames, card)
    end
end

