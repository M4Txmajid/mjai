            local newName = GetRealBrainrotName(brainrot)
            if newName ~= data.realName then
                data.realName = newName
            end
            UpdateESP(brainrot, data.esp, data.folder, data.realName)
        else
            RemoveESP(data.esp)
            ESPObjects[brainrot] = nil
        end
    end
end)

